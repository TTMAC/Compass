---
import EmailCapture from "@components/EmailCapture.astro";
import { pillars } from "@content/pillars";
const currentYear = new Date().getFullYear();
---

<footer class="bg-bg-secondary border-t border-gray-100 mt-auto" role="contentinfo">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <p class="font-heading font-bold text-lg text-compass-green mb-2">
          GovCompass
        </p>
        <p class="text-sm text-text-secondary">
          Making South Africa's governance system legible to ordinary citizens.
        </p>
      </div>

      <!-- Topics -->
      <div>
        <p class="font-heading font-semibold text-sm text-text-primary mb-3">
          Topics
        </p>
        <ul class="space-y-2" role="list">
          <li>
            <a
              href="/big-picture"
              class="text-sm text-text-secondary hover:text-compass-green transition-colors"
            >
              The Big Picture
            </a>
          </li>
          {pillars.map((p) => (
            <li>
              <a
                href={`/pillars/${p.slug}`}
                class="text-sm text-text-secondary hover:text-compass-green transition-colors"
              >
                {p.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- About & Legal -->
      <div>
        <p class="font-heading font-semibold text-sm text-text-primary mb-3">
          About & Legal
        </p>
        <ul class="space-y-2" role="list">
          <li>
            <a
              href="/real-steps-to-reform"
              class="text-sm text-text-secondary hover:text-compass-green transition-colors"
            >
              Reform Roadmap
            </a>
          </li>
          <li>
            <a
              href="/diagnostic-frameworks"
              class="text-sm text-text-secondary hover:text-compass-green transition-colors"
            >
              Diagnostic Frameworks
            </a>
          </li>
          <li>
            <a
              href="/about"
              class="text-sm text-text-secondary hover:text-compass-green transition-colors"
            >
              About
            </a>
          </li>
          <li>
            <a
              href="/subscribe"
              class="text-sm text-text-secondary hover:text-compass-green transition-colors"
            >
              Subscribe
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="text-sm text-text-secondary hover:text-compass-green transition-colors"
            >
              Contact
            </a>
          </li>
          <li>
            <a
              href="/privacy"
              class="text-sm text-text-secondary hover:text-compass-green transition-colors"
            >
              Privacy Policy
            </a>
          </li>
          <li>
            <button
              type="button"
              class="text-sm text-text-secondary hover:text-compass-green transition-colors"
              data-cookie-settings
            >
              Cookie Settings
            </button>
          </li>
        </ul>
      </div>

      <!-- Subscribe -->
      <div>
        <p class="font-heading font-semibold text-sm text-text-primary mb-3">
          Stay informed
        </p>
        <p class="text-sm text-text-secondary mb-3">
          Get new articles delivered to your inbox.
        </p>
        <EmailCapture location="footer" />
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-gray-200 text-center">
      <p class="text-xs text-text-secondary">
        &copy; {currentYear} GovCompass. Essential political education you should know on how your government works for you.
      </p>
    </div>
  </div>
</footer>

<script>
  const cookieBtn = document.querySelector("[data-cookie-settings]");
  if (cookieBtn) {
    cookieBtn.addEventListener("click", () => {
      if (typeof (window as any).openCookieConsent === "function") {
        (window as any).openCookieConsent();
      }
    });
  }
</script>
