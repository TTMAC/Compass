---
import { getPillarBySlug } from "@content/pillars";

interface Props {
  articleNumber: string;
  title: string;
  sphere?: ("national" | "provincial" | "municipal" | "all")[];
  readingTime: number;
  status: "published" | "draft" | "coming-soon" | "scheduled";
  slug: string;
  pillar?: string;
}

const { articleNumber, title, sphere, readingTime, status, slug, pillar } = Astro.props;

const sphereColors: Record<string, string> = {
  national: "bg-sphere-national",
  provincial: "bg-sphere-provincial",
  municipal: "bg-sphere-municipal",
  all: "bg-compass-green",
};

const isClickable = status === "published" || status === "draft";
const pillarConfig = pillar ? getPillarBySlug(pillar) : undefined;
---

<a
  href={isClickable ? `/articles/${slug}` : undefined}
  class={`block border border-gray-200 rounded-lg p-4 transition-colors ${
    isClickable
      ? "hover:border-compass-green cursor-pointer"
      : "opacity-60 cursor-default"
  }`}
  data-testid="series-card"
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <div class="flex items-center gap-2 mb-1">
        {pillarConfig && (
          <span
            class="inline-block w-2.5 h-2.5 rounded-full shrink-0"
            style={`background-color: ${pillarConfig.color}`}
            title={pillarConfig.title}
          ></span>
        )}
        <span class="font-heading text-xs text-text-secondary">
          {articleNumber}
        </span>
        {sphere?.map((s) => (
          <span
            class={`inline-block px-1.5 py-0.5 text-[10px] font-heading font-semibold text-white rounded ${sphereColors[s]}`}
          >
            {s.charAt(0).toUpperCase() + s.slice(1)}
          </span>
        ))}
        {
          (status === "coming-soon" || status === "scheduled") && (
            <span class="text-[10px] font-heading text-text-secondary bg-bg-secondary px-1.5 py-0.5 rounded">
              Coming soon
            </span>
          )
        }
        {
          status === "draft" && (
            <span class="text-[10px] font-heading text-amber-700 bg-amber-100 px-1.5 py-0.5 rounded">
              Draft
            </span>
          )
        }
      </div>
      <h3 class="font-heading text-base font-semibold text-text-primary">
        {title}
      </h3>
    </div>
    {
      isClickable && (
        <span class="font-heading text-xs text-text-secondary whitespace-nowrap">
          {readingTime} min
        </span>
      )
    }
  </div>
</a>
