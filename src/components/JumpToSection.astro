---
export interface JumpLink {
  href: string;
  label: string;
}

interface Props {
  links: JumpLink[];
  label?: string;
  class?: string;
}

const { links, label = "Jump to section", class: className = "" } = Astro.props;
---

<nav class:list={["mb-8 border border-gray-200 rounded-lg bg-bg-secondary p-4", className]} aria-label={label}>
  <p class="font-heading text-xs font-semibold text-text-secondary uppercase tracking-wide mb-2">
    {label}
  </p>
  <ul class="flex flex-wrap gap-2">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class="inline-block text-sm font-heading font-semibold text-text-primary bg-white border border-gray-200 rounded-full px-3 py-1.5 hover:border-compass-green hover:text-compass-green focus:outline-none focus-visible:ring-2 focus-visible:ring-compass-green focus-visible:ring-offset-2 transition-colors"
          set:html={link.label}
        />
      </li>
    ))}
  </ul>
</nav>
