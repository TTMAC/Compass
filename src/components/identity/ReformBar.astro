---
import { SignOutButton } from "@clerk/astro/components";
import ClerkBoot from "./ClerkBoot.astro";

/**
 * Thin "members area" bar shown at the top of every gated /reform/* page.
 * Carries the manual Clerk boot (<ClerkBoot />) plus a sign-out control.
 *
 * When Clerk is not configured the gate is dormant: the sign-out button would
 * have nothing to act on, so we hide it and show a neutral label instead. This
 * keeps dev and open deploy previews clean.
 */
const enabled = !!import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY;
---

<ClerkBoot />

<div
  class="bg-compass-green-light border-b border-compass-green/20"
  data-reform-bar
>
  <div
    class="max-w-content mx-auto px-4 md:px-0 py-2 flex items-center justify-between gap-3"
  >
    <span
      class="inline-flex items-center gap-1.5 font-heading text-xs font-semibold text-compass-green"
    >
      <svg
        class="w-3.5 h-3.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
        ></path>
      </svg>
      Reform — members area
    </span>
    {
      enabled && (
        <SignOutButton
          redirectUrl="/"
          class="font-heading text-xs font-semibold text-compass-green hover:underline cursor-pointer"
        >
          Sign out
        </SignOutButton>
      )
    }
  </div>
</div>
