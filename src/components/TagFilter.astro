---
interface Props {
  tags: string[];
  tagCounts?: Record<string, number>;
  initialVisible?: number;
  pillarColor?: string;
}

const { tags, tagCounts = {}, initialVisible = 6, pillarColor = "#1B6B4A" } = Astro.props;
const hasOverflow = tags.length > initialVisible;
---

<div data-testid="tag-filter" class="mb-6" data-pillar-color={pillarColor}>
  <div class="flex flex-wrap gap-2" role="group" aria-label="Filter by tag">
    <button
      type="button"
      class="px-3 py-1.5 text-sm font-heading font-semibold rounded transition-colors text-white"
      style={`background-color: ${pillarColor};`}
      data-tag="all"
      aria-pressed="true"
    >
      All
    </button>
    {tags.map((tag, i) => (
      <button
        type="button"
        class:list={[
          "px-3 py-1.5 text-sm font-heading font-semibold rounded transition-colors bg-gray-100 text-text-secondary hover:bg-gray-200",
          { "hidden": hasOverflow && i >= initialVisible },
        ]}
        data-tag={tag}
        data-tag-index={i}
        aria-pressed="false"
      >
        {tag.charAt(0).toUpperCase() + tag.slice(1)}
        {tagCounts[tag] !== undefined && (
          <span class="ml-1 text-[10px] opacity-70">({tagCounts[tag]})</span>
        )}
      </button>
    ))}
    {hasOverflow && (
      <button
        type="button"
        class="px-3 py-1.5 text-sm font-heading font-semibold rounded transition-colors border border-dashed border-gray-300 text-text-secondary hover:bg-gray-50"
        data-tag-toggle
        aria-expanded="false"
      >
        +{tags.length - initialVisible} more
      </button>
    )}
  </div>
</div>

<script define:vars={{ initialVisible }}>
  const filterContainer = document.querySelector('[data-testid="tag-filter"]');
  const filterButtons = filterContainer?.querySelectorAll("button[data-tag]");
  const toggleBtn = filterContainer?.querySelector("[data-tag-toggle]");
  const cards = document.querySelectorAll("[data-testid='series-card']");

  // Expand / collapse
  if (toggleBtn) {
    let expanded = false;
    toggleBtn.addEventListener("click", () => {
      expanded = !expanded;
      toggleBtn.setAttribute("aria-expanded", String(expanded));

      filterContainer?.querySelectorAll("button[data-tag-index]").forEach((btn) => {
        const idx = Number(btn.getAttribute("data-tag-index"));
        if (idx >= initialVisible) {
          btn.classList.toggle("hidden", !expanded);
        }
      });

      const hiddenCount = filterContainer?.querySelectorAll("button[data-tag-index].hidden").length ?? 0;
      const totalOverflow = filterContainer?.querySelectorAll("button[data-tag-index]").length - initialVisible;
      toggleBtn.textContent = expanded ? "Show less" : `+${totalOverflow} more`;
    });
  }

  // Tag filtering
  const pillarColor = filterContainer?.getAttribute("data-pillar-color") || "#1B6B4A";

  filterButtons?.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tag = btn.getAttribute("data-tag") || "all";

      filterButtons.forEach((b) => {
        b.setAttribute("aria-pressed", "false");
        b.className = b.className
          .replace("text-white", "")
          .replace("bg-gray-100 text-text-secondary hover:bg-gray-200", "")
          .trim()
          + " bg-gray-100 text-text-secondary hover:bg-gray-200";
        b.style.backgroundColor = "";
      });

      btn.setAttribute("aria-pressed", "true");
      btn.className = btn.className
        .replace("bg-gray-100 text-text-secondary hover:bg-gray-200", "")
        .trim()
        + " text-white";
      btn.style.backgroundColor = pillarColor;

      cards.forEach((card) => {
        const cardEl = card;
        if (tag === "all") {
          cardEl.style.display = "";
        } else {
          const cardTags = cardEl.getAttribute("data-tags")?.split(",") || [];
          cardEl.style.display = cardTags.includes(tag) ? "" : "none";
        }
      });
    });
  });
</script>
