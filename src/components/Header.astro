---
import { pillars } from "@content/pillars";
import { Show, SignInButton, UserButton } from "@clerk/astro/components";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/data-sources", label: "Data Sources" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const mobileNavLinks = [
  { href: "/", label: "Home" },
  { href: "/data-sources", label: "Data Sources" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const reformLinks = [
  { href: "/reform-programme", label: "The Reform Programme" },
  { href: "/leading-and-lagging-metrics", label: "Leading & Lagging Metrics" },
  { href: "/reform-scorecard", label: "Reinforcing Cycle Scorecard" },
  { href: "/diagnostic-frameworks", label: "Diagnostic Frameworks" },
  { href: "/real-steps-to-reform", label: "Reform Roadmap" },
];

const topicsLinks = [
  { href: "/big-picture", label: "The Big Picture" },
  { href: "/government-functions", label: "State Functions" },
  ...pillars.map((p) => ({ href: `/pillars/${p.slug}`, label: p.title })),
  { href: "/grand-strategy", label: "Grand Strategy" },
  { href: "/advocacy-playbooks", label: "Advocacy Playbooks" },
  { href: "/glossary", label: "Glossary" },
];

const currentPath = Astro.url.pathname;
const isTopicsActive =
  currentPath.startsWith("/pillars") ||
  currentPath === "/big-picture" ||
  currentPath.startsWith("/government-functions") ||
  currentPath === "/grand-strategy" ||
  currentPath === "/advocacy-playbooks" ||
  currentPath === "/glossary";

const isDev = import.meta.env.DEV && !import.meta.env.PUBLIC_DEV_SEARCH;
const isReformActive =
  currentPath === "/reform-programme" ||
  currentPath === "/leading-and-lagging-metrics" ||
  currentPath === "/reform-scorecard" ||
  currentPath === "/diagnostic-frameworks" ||
  currentPath === "/real-steps-to-reform";
---

<header
  class="bg-bg-primary border-b border-gray-100 sticky top-0 z-40"
  role="banner"
>
  <nav
    class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="font-heading font-bold text-xl text-compass-green shrink-0"
    >
      GovCompass
    </a>

    <!-- Desktop nav -->
    <ul
      class="hidden lg:flex items-center gap-3 whitespace-nowrap"
      role="list"
    >
      <li>
        <a
          href="/"
          class={`font-heading text-sm transition-colors hover:text-compass-green ${
            currentPath === "/"
              ? "text-compass-green font-semibold"
              : "text-text-secondary"
          }`}
          aria-current={currentPath === "/" ? "page" : undefined}
        >
          Home
        </a>
      </li>

      <!-- Topics dropdown -->
      <li class="relative group">
        <button
          type="button"
          class={`font-heading text-sm transition-colors hover:text-compass-green flex items-center gap-1 ${
            isTopicsActive
              ? "text-compass-green font-semibold"
              : "text-text-secondary"
          }`}
          aria-expanded="false"
          aria-haspopup="true"
        >
          Topics
          <svg
            class="w-3 h-3 transition-transform group-hover:rotate-180 group-focus-within:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <ul
          class="absolute left-0 top-full pt-2 hidden group-hover:block group-focus-within:block z-50"
          role="list"
        >
          <li>
            <div
              class="bg-bg-primary border border-gray-200 rounded-lg shadow-lg py-2 min-w-[220px]"
            >
              {
                topicsLinks.map((link) => (
                  <a
                    href={link.href}
                    class={`block px-4 py-2 font-heading text-sm transition-colors hover:bg-compass-green-light hover:text-compass-green ${
                      currentPath === link.href
                        ? "text-compass-green font-semibold bg-compass-green-light"
                        : "text-text-secondary"
                    }`}
                    aria-current={
                      currentPath === link.href ? "page" : undefined
                    }
                  >
                    {link.label}
                  </a>
                ))
              }
            </div>
          </li>
        </ul>
      </li>

      <!-- Reform dropdown -->
      <li class="relative group/reform">
        <button
          type="button"
          class={`font-heading text-sm transition-colors hover:text-compass-green flex items-center gap-1 ${
            isReformActive
              ? "text-compass-green font-semibold"
              : "text-text-secondary"
          }`}
          aria-expanded="false"
          aria-haspopup="true"
        >
          Reform
          <Show when="signed-out">
            <span class="text-xs leading-none" aria-hidden="true">🔒</span>
          </Show>
          <svg
            class="w-3 h-3 transition-transform group-hover/reform:rotate-180 group-focus-within/reform:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <ul
          class="absolute left-0 top-full pt-2 hidden group-hover/reform:block group-focus-within/reform:block z-50"
          role="list"
        >
          <li>
            <div
              class="bg-bg-primary border border-gray-200 rounded-lg shadow-lg py-2 min-w-[220px]"
            >
              <Show when="signed-out">
                <SignInButton mode="modal">
                  <button
                    type="button"
                    class="w-full flex items-center gap-2 px-4 py-2 mb-1 border-b border-gray-100 font-heading text-xs text-compass-green hover:bg-compass-green-light transition-colors"
                  >
                    <span aria-hidden="true">🔒</span>
                    <span>Sign in to view</span>
                  </button>
                </SignInButton>
              </Show>
              {
                reformLinks.map((link) => (
                  <a
                    href={link.href}
                    class={`block px-4 py-2 font-heading text-sm transition-colors hover:bg-compass-green-light hover:text-compass-green ${
                      currentPath === link.href
                        ? "text-compass-green font-semibold bg-compass-green-light"
                        : "text-text-secondary"
                    }`}
                    aria-current={
                      currentPath === link.href ? "page" : undefined
                    }
                  >
                    {link.label}
                  </a>
                ))
              }
            </div>
          </li>
        </ul>
      </li>

      {
        navLinks.slice(1).map((link) => (
          <li>
            <a
              href={link.href}
              class={`font-heading text-sm transition-colors hover:text-compass-green ${
                currentPath === link.href
                  ? "text-compass-green font-semibold"
                  : "text-text-secondary"
              }`}
              aria-current={currentPath === link.href ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <div id="search-desktop" class="w-36" aria-live="polite">
          {
            isDev && (
              <p
                class="text-xs text-text-secondary italic px-2 py-1.5 border border-dashed border-gray-300 rounded"
                title="Search is generated at build time. Run `npm run build && npm run preview` to test."
              >
                Search: preview only
              </p>
            )
          }
        </div>
      </li>

      <!-- Auth controls -->
      <li class="flex items-center">
        <Show when="signed-out">
          <SignInButton mode="modal">
            <button
              type="button"
              class="font-heading text-sm font-semibold text-white bg-compass-green rounded-md px-3 py-1.5 transition-opacity hover:opacity-90"
            >
              Sign in
            </button>
          </SignInButton>
        </Show>
        <Show when="signed-in">
          <UserButton />
        </Show>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button
      type="button"
      class="lg:hidden flex items-center justify-center w-12 h-12 -mr-2"
      aria-label="Open menu"
      aria-expanded="false"
      data-menu-toggle
    >
      <svg
        class="w-6 h-6 text-text-primary"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        aria-hidden="true"
        data-menu-icon
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"
          data-menu-icon-path></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    class="lg:hidden overflow-hidden transition-all duration-[250ms] ease-in-out max-h-0"
    data-mobile-menu
    aria-hidden="true"
  >
    <div class="px-4 py-4 border-t border-gray-100 space-y-1">
      <!-- Auth controls -->
      <div class="flex items-center gap-3 mb-3 pb-3 border-b border-gray-100">
        <Show when="signed-out">
          <SignInButton mode="modal">
            <button
              type="button"
              class="flex-1 font-heading text-sm font-semibold text-white bg-compass-green rounded-md py-2 transition-opacity hover:opacity-90"
            >
              Sign in
            </button>
          </SignInButton>
        </Show>
        <Show when="signed-in">
          <UserButton />
          <span class="font-heading text-sm text-text-secondary">Account</span>
        </Show>
      </div>

      <div id="search-mobile" class="mb-3" aria-live="polite">
        {
          isDev && (
            <p
              class="text-xs text-text-secondary italic px-3 py-2 border border-dashed border-gray-300 rounded"
              title="Search is generated at build time. Run `npm run build && npm run preview` to test."
            >
              Search: preview only
            </p>
          )
        }
      </div>
      <ul class="space-y-1" role="list">
        <li>
          <a
            href="/"
            class={`block py-3 px-3 font-heading text-sm rounded transition-colors hover:bg-compass-green-light hover:text-compass-green ${
              currentPath === "/"
                ? "text-compass-green font-semibold bg-compass-green-light"
                : "text-text-secondary"
            }`}
            aria-current={currentPath === "/" ? "page" : undefined}
          >
            Home
          </a>
        </li>

        <!-- Topics accordion -->
        <li>
          <details class="group/topics">
            <summary
              class={`flex items-center justify-between py-3 px-3 font-heading text-sm rounded transition-colors cursor-pointer hover:bg-compass-green-light hover:text-compass-green list-none [&::-webkit-details-marker]:hidden ${
                isTopicsActive
                  ? "text-compass-green font-semibold bg-compass-green-light"
                  : "text-text-secondary"
              }`}
            >
              Topics
              <svg
                class="w-3 h-3 transition-transform group-open/topics:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <ul class="pl-4 space-y-1 mt-1" role="list">
              {
                topicsLinks.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class={`block py-2 px-3 font-heading text-sm rounded transition-colors hover:bg-compass-green-light hover:text-compass-green ${
                        currentPath === link.href
                          ? "text-compass-green font-semibold"
                          : "text-text-secondary"
                      }`}
                      aria-current={
                        currentPath === link.href ? "page" : undefined
                      }
                    >
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </details>
        </li>

        <!-- Reform accordion -->
        <li>
          <details class="group/reform">
            <summary
              class={`flex items-center justify-between py-3 px-3 font-heading text-sm rounded transition-colors cursor-pointer hover:bg-compass-green-light hover:text-compass-green list-none [&::-webkit-details-marker]:hidden ${
                isReformActive
                  ? "text-compass-green font-semibold bg-compass-green-light"
                  : "text-text-secondary"
              }`}
            >
              <span class="flex items-center gap-1.5">
                Reform
                <Show when="signed-out">
                  <span class="text-xs leading-none" aria-hidden="true">🔒</span>
                </Show>
              </span>
              <svg
                class="w-3 h-3 transition-transform group-open/reform:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <ul class="pl-4 space-y-1 mt-1" role="list">
              <Show when="signed-out">
                <li>
                  <SignInButton mode="modal">
                    <button
                      type="button"
                      class="w-full flex items-center gap-2 py-2 px-3 font-heading text-xs text-compass-green rounded hover:bg-compass-green-light transition-colors"
                    >
                      <span aria-hidden="true">🔒</span>
                      <span>Sign in to view</span>
                    </button>
                  </SignInButton>
                </li>
              </Show>
              {
                reformLinks.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class={`block py-2 px-3 font-heading text-sm rounded transition-colors hover:bg-compass-green-light hover:text-compass-green ${
                        currentPath === link.href
                          ? "text-compass-green font-semibold"
                          : "text-text-secondary"
                      }`}
                      aria-current={
                        currentPath === link.href ? "page" : undefined
                      }
                    >
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </details>
        </li>

        {
          mobileNavLinks.slice(1).map((link) => (
            <li>
              <a
                href={link.href}
                class={`block py-3 px-3 font-heading text-sm rounded transition-colors hover:bg-compass-green-light hover:text-compass-green ${
                  currentPath === link.href
                    ? "text-compass-green font-semibold bg-compass-green-light"
                    : "text-text-secondary"
                }`}
                aria-current={currentPath === link.href ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</header>

{!isDev && <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />}

<script>
  const toggle = document.querySelector("[data-menu-toggle]");
  const menu = document.querySelector("[data-mobile-menu]");
  const iconPath = document.querySelector("[data-menu-icon-path]");

  const HAMBURGER_D = "M4 6h16M4 12h16M4 18h16";
  const CLOSE_D = "M6 18L18 6M6 6l12 12";

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Open menu" : "Close menu");
      menu.setAttribute("aria-hidden", String(isOpen));

      if (iconPath) {
        iconPath.setAttribute("d", isOpen ? HAMBURGER_D : CLOSE_D);
      }

      if (isOpen) {
        (menu as HTMLElement).style.maxHeight = "0";
      } else {
        (menu as HTMLElement).style.maxHeight = menu.scrollHeight + "px";
      }
    });
  }

  // Recalculate mobile menu height when accordions toggle
  const mobileAccordions = menu?.querySelectorAll("details");
  if (mobileAccordions && menu) {
    mobileAccordions.forEach((details) => {
      details.addEventListener("toggle", () => {
        const isMenuOpen = toggle?.getAttribute("aria-expanded") === "true";
        if (isMenuOpen) {
          (menu as HTMLElement).style.maxHeight = menu.scrollHeight + "px";
        }
      });
    });
  }

  // Desktop dropdowns: toggle aria-expanded on hover/focus
  function setupDropdown(selector: string) {
    const btn = document.querySelector<HTMLButtonElement>(selector);
    const parent = btn?.closest("li");
    if (btn && parent) {
      const setExpanded = (expanded: boolean) => {
        btn.setAttribute("aria-expanded", String(expanded));
      };
      parent.addEventListener("mouseenter", () => setExpanded(true));
      parent.addEventListener("mouseleave", () => setExpanded(false));
      parent.addEventListener("focusin", () => setExpanded(true));
      parent.addEventListener("focusout", (e) => {
        if (!parent.contains((e as FocusEvent).relatedTarget as Node)) {
          setExpanded(false);
        }
      });
    }
  }

  setupDropdown("li.group button[aria-haspopup]");
  setupDropdown("li.group\\/reform button[aria-haspopup]");

  // Load Pagefind UI on-demand
  async function initPagefind() {
    try {
      const script = document.createElement("script");
      script.src = "/pagefind/pagefind-ui.js";
      script.onerror = () => {
        /* Pagefind failed to load — search unavailable */
      };
      script.onload = () => {
        try {
          const PagefindUI = (window as any).PagefindUI;
          if (!PagefindUI) return;

          const desktopEl = document.getElementById("search-desktop");
          const mobileEl = document.getElementById("search-mobile");

          if (desktopEl) {
            new PagefindUI({
              element: desktopEl,
              showSubResults: false,
              showImages: false,
            });
          }
          if (mobileEl) {
            new PagefindUI({
              element: mobileEl,
              showSubResults: false,
              showImages: false,
            });
          }
        } catch {
          /* Pagefind init failed — search unavailable */
        }
      };
      document.head.appendChild(script);
    } catch {
      /* Script injection failed */
    }
  }

  if (import.meta.env.PROD || import.meta.env.PUBLIC_DEV_SEARCH) {
    initPagefind();
  }
</script>
