---
---

<div class="mx-auto max-w-xl">
  <svg width="680" height="560" viewBox="0 0 680 560" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" role="img" aria-label="Causal loop diagram showing the reinforcing cycle between governance, safety, economic growth, and human development in South Africa" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;">
    <defs>
      <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse"><path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></marker>
      <marker id="arrow-dash" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse"><path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></marker>
    </defs>

    <!-- Symmetric quarter-arc arrows (counter-clockwise) -->

    <!-- Gov Structure → Safety & Security -->
    <path d="M 240,72 Q 120,72 120,246" fill="none" stroke="#888780" stroke-width="1.2" marker-end="url(#arrow)"/>
    <text x="108" y="148" text-anchor="end" font-size="12" fill="#5F5E5A">Institutional</text>
    <text x="108" y="164" text-anchor="end" font-size="12" fill="#5F5E5A">capacity</text>

    <!-- Safety & Security → Human Development -->
    <path d="M 120,294 Q 120,468 240,468" fill="none" stroke="#888780" stroke-width="1.2" marker-end="url(#arrow)"/>
    <text x="108" y="388" text-anchor="end" font-size="12" fill="#5F5E5A">Security enables</text>
    <text x="108" y="404" text-anchor="end" font-size="12" fill="#5F5E5A">development</text>

    <!-- Human Development → Economic Growth -->
    <path d="M 440,468 Q 560,468 560,294" fill="none" stroke="#888780" stroke-width="1.2" marker-end="url(#arrow)"/>
    <text x="568" y="388" text-anchor="start" font-size="12" fill="#5F5E5A">Skills &amp;</text>
    <text x="568" y="404" text-anchor="start" font-size="12" fill="#5F5E5A">productivity</text>

    <!-- Economic Growth → Government Structure -->
    <path d="M 560,246 Q 560,72 440,72" fill="none" stroke="#888780" stroke-width="1.2" marker-end="url(#arrow)"/>
    <text x="568" y="148" text-anchor="start" font-size="12" fill="#5F5E5A">Tax base &amp;</text>
    <text x="568" y="164" text-anchor="start" font-size="12" fill="#5F5E5A">fiscal space</text>

    <!-- CENTER HUB -->
    <circle cx="340" cy="270" r="62" fill="none" stroke="#D3D1C7" stroke-width="0.5" stroke-dasharray="3 3"/>
    <circle cx="340" cy="270" r="50" fill="#F8F7F4" stroke="#B4B2A9" stroke-width="0.8"/>
    <circle cx="340" cy="270" r="36" fill="#FFFFFF" stroke="#B4B2A9" stroke-width="0.5"/>

    <!-- Rotating arrows icon -->
    <g transform="translate(340,270)">
      <path d="M 4,-18 A 18,18 0 0,1 16,8" fill="none" stroke="#5F5E5A" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M 14,3 L 17,9 L 11,9" fill="#5F5E5A" stroke="none"/>
      <path d="M 12,12 A 18,18 0 0,1 -14,6" fill="none" stroke="#5F5E5A" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M -11,10 L -16,6 L -10,3" fill="#5F5E5A" stroke="none"/>
      <path d="M -12,-2 A 18,18 0 0,1 0,-20" fill="none" stroke="#5F5E5A" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M -3,-17 L 1,-22 L 4,-16" fill="#5F5E5A" stroke="none"/>
      <text x="0" y="1" text-anchor="middle" dominant-baseline="central" font-size="13" font-weight="500" fill="#2C2C2A">R</text>
    </g>

    <!-- Investment climate label -->
    <text x="340" y="348" text-anchor="middle" font-size="12" fill="#5F5E5A" font-style="italic">Investment climate</text>

    <!-- Dashed connectors -->
    <line x1="450" y1="270" x2="402" y2="270" stroke="#888780" stroke-width="1" stroke-dasharray="4 3" marker-end="url(#arrow-dash)"/>
    <line x1="278" y1="270" x2="220" y2="270" stroke="#888780" stroke-width="1" stroke-dasharray="4 3" marker-end="url(#arrow-dash)"/>

    <!-- Government Structure (top) -->
    <a href="/pillars/government-structure">
      <rect x="240" y="48" width="200" height="48" rx="8" fill="#C0DD97" stroke="#3B6D11" stroke-width="0.5" class="hover:opacity-90 transition-opacity"/>
      <text x="340" y="72" text-anchor="middle" dominant-baseline="central" font-size="14" font-weight="500" fill="#27500A">Government structure</text>
    </a>

    <!-- Economic Growth (right) -->
    <a href="/pillars/economic-growth">
      <rect x="460" y="246" width="200" height="48" rx="8" fill="#FAC775" stroke="#854F0B" stroke-width="0.5" class="hover:opacity-90 transition-opacity"/>
      <text x="560" y="270" text-anchor="middle" dominant-baseline="central" font-size="14" font-weight="500" fill="#633806">Economic growth</text>
    </a>

    <!-- Human Development (bottom) -->
    <a href="/pillars/human-development">
      <rect x="240" y="444" width="200" height="48" rx="8" fill="#CECBF6" stroke="#534AB7" stroke-width="0.5" class="hover:opacity-90 transition-opacity"/>
      <text x="340" y="468" text-anchor="middle" dominant-baseline="central" font-size="14" font-weight="500" fill="#3C3489">Human development</text>
    </a>

    <!-- Safety & Security (left) -->
    <a href="/pillars/safety-security">
      <rect x="20" y="246" width="200" height="48" rx="8" fill="#9FE1CB" stroke="#0F6E56" stroke-width="0.5" class="hover:opacity-90 transition-opacity"/>
      <text x="120" y="270" text-anchor="middle" dominant-baseline="central" font-size="14" font-weight="500" fill="#085041">Safety &amp; security</text>
    </a>

    <!-- Caption -->
    <text x="340" y="530" text-anchor="middle" font-size="12" fill="#5F5E5A">A reinforcing loop: when any node strengthens, it lifts its neighbours.</text>
    <text x="340" y="546" text-anchor="middle" font-size="12" fill="#5F5E5A">When any node weakens, decline cascades through the system.</text>
  </svg>
</div>
