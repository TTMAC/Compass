---
import PageLayout from "@layouts/PageLayout.astro";

const levels = [
  {
    id: "national",
    label: "National Department",
    color: "#1B6B4A",
    lightColor: "#E8F5EE",
    downloadUrl: "/downloads/JCPS_Reform_Advocacy_Playbook.pdf",
    downloadLabel: "Download Full JCPS Playbook (PDF)",
  },
  {
    id: "provincial",
    label: "Provincial Government",
    color: "#2563EB",
    lightColor: "#EFF6FF",
    downloadUrl: "/downloads/Education_Reform_Advocacy_Playbook.pdf",
    downloadLabel: "Download Full Education Playbook (PDF)",
  },
  {
    id: "municipal",
    label: "Municipality",
    color: "#D97706",
    lightColor: "#FFFBEB",
    downloadUrl: "/downloads/Johannesburg_Metro_Reform_Playbook.pdf",
    downloadLabel: "Download Full JHB Metro Playbook (PDF)",
  },
];
---

<PageLayout
  title="Advocacy Playbooks for Citizens"
  description="Practical playbooks for civil society coalitions organising for reform at national, provincial, and municipal government level in South Africa."
>
  <!-- Hero -->
  <header class="mb-10">
    <h1 class="font-heading text-3xl md:text-4xl font-bold text-text-primary mb-3">
      Advocacy Playbooks for Citizens
    </h1>
    <p class="text-lg text-text-secondary leading-relaxed mb-4">
      Government reform does not happen by itself. It requires organised, sustained pressure from civil society — coalitions of NGOs, community organisations, researchers, legal advocates, and ordinary citizens working together with strategic discipline.
    </p>
    <p class="text-text-secondary leading-relaxed mb-4">
      These playbooks are practical examples designed for individuals and groups looking for a starting point. Whether you are a single concerned citizen, a community organisation, or a broader coalition, each playbook offers a structured perspective on how to begin — from identifying problems to building alliances and driving change.
    </p>
    <p class="text-text-secondary leading-relaxed">
      The playbooks can be adapted to fit your relevant context, whether you are engaging at National, Provincial, or Municipal level. The specific issues and stakeholders will differ, but the core structures — diagnosis, coalition-building, strategy, and escalation — remain consistent across all three spheres. Choose a level below to explore, and download the full PDF for offline use.
    </p>
  </header>

  <!-- Pill Switcher -->
  <div class="sticky top-16 bg-bg-primary py-3 z-30 border-b border-gray-100 mb-8">
    <div
      class="flex flex-wrap items-center gap-2"
      role="tablist"
      aria-label="Select government level"
    >
      {levels.map((level, i) => (
        <button
          type="button"
          role="tab"
          class="playbook-tab px-4 py-2 rounded-full font-heading text-sm font-semibold transition-colors border-2"
          style={i === 0
            ? `border-color: ${level.color}; background-color: ${level.color}; color: white`
            : `border-color: ${level.color}; color: ${level.color}; background-color: transparent`}
          data-tab={level.id}
          data-color={level.color}
          data-light={level.lightColor}
          aria-selected={i === 0 ? "true" : "false"}
          aria-controls={`panel-${level.id}`}
          id={`tab-${level.id}`}
        >
          {level.label}
        </button>
      ))}
    </div>
  </div>

  <!-- ===================== NATIONAL PANEL ===================== -->
  <section
    id="panel-national"
    role="tabpanel"
    aria-labelledby="tab-national"
    class="playbook-panel"
    data-panel="national"
  >
    <!-- Download banner -->
    <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-8">
      <div>
        <p class="font-heading font-semibold text-text-primary text-sm">Voices for Justice — JCPS Reform Playbook</p>
        <p class="text-text-secondary text-xs mt-0.5">Justice, Constitutional Development, Correctional Services, Safety &amp; Security</p>
      </div>
      <a
        href="/downloads/JCPS_Reform_Advocacy_Playbook.pdf"
        download
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-compass-green text-white font-heading text-sm font-semibold hover:bg-compass-green-dark transition-colors shrink-0"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" /></svg>
        Download Full Playbook (PDF)
      </a>
    </div>

    <!-- Why This Playbook -->
    <div class="mb-10">
      <h2 class="font-heading text-2xl font-bold text-text-primary mb-3">Why This Playbook Exists</h2>
      <p class="text-text-secondary leading-relaxed mb-3">
        South Africa's justice, safety, and security systems touch every community. When they work, people feel protected and rights are respected. When they fail, the consequences fall hardest on the poorest and most vulnerable.
      </p>
      <p class="text-text-secondary leading-relaxed">
        This playbook assumes you are working <strong class="text-text-primary">with</strong> government where possible, and <strong class="text-text-primary">against</strong> it where necessary. Reform advocacy requires strategic judgement about when to collaborate, when to expose, when to litigate, and when to mobilise.
      </p>
    </div>

    <!-- Coalition Architecture -->
    <details class="mb-6 group border border-gray-200 rounded-lg" open>
      <summary class="flex items-center justify-between p-4 cursor-pointer font-heading font-semibold text-text-primary hover:bg-gray-50 rounded-lg">
        <span>1. Coalition Architecture</span>
        <svg class="w-4 h-4 text-text-secondary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </summary>
      <div class="px-4 pb-4">
        <p class="text-text-secondary leading-relaxed mb-4">A well-structured civil society coalition for JCPS reform operates across four layers:</p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead><tr class="bg-gray-50"><th class="text-left p-2 font-heading font-semibold border-b">Layer</th><th class="text-left p-2 font-heading font-semibold border-b">Who Belongs</th><th class="text-left p-2 font-heading font-semibold border-b">Function</th></tr></thead>
            <tbody>
              <tr class="border-b"><td class="p-2 font-semibold">Steering Body</td><td class="p-2">Senior leaders of core organisations</td><td class="p-2">Strategic direction, public positioning, coalition-wide commitments</td></tr>
              <tr class="border-b"><td class="p-2 font-semibold">Thematic Working Groups</td><td class="p-2">Programme staff, researchers, lawyers, organisers</td><td class="p-2">Evidence gathering, policy submissions, litigation strategy</td></tr>
              <tr class="border-b"><td class="p-2 font-semibold">Community Networks</td><td class="p-2">CBOs, faith communities, survivor groups</td><td class="p-2">Ground-level evidence, lived experience, local accountability</td></tr>
              <tr><td class="p-2 font-semibold">Solidarity Partners</td><td class="p-2">Media, academia, international allies</td><td class="p-2">Amplify voice, extend reach, resource mobilisation</td></tr>
            </tbody>
          </table>
        </div>
        <h4 class="font-heading font-semibold text-text-primary mt-5 mb-2">Key Coalition Roles</h4>
        <ul class="text-text-secondary text-sm space-y-1 list-disc pl-5">
          <li><strong>Convenor</strong> — holds space, manages relationships, coordinates logistics</li>
          <li><strong>Public Spokesperson</strong> — credible, media-trained, politically savvy</li>
          <li><strong>Legal &amp; Policy Lead</strong> — owns litigation and policy strategy</li>
          <li><strong>Research &amp; Evidence Lead</strong> — data analysis, report production</li>
          <li><strong>Community Accountability Lead</strong> — ensures lived experience is centred</li>
          <li><strong>Communications Lead</strong> — media, social media, narrative strategy</li>
          <li><strong>Resource Mobilisation Lead</strong> — fundraising and donor engagement</li>
        </ul>
      </div>
    </details>

    <!-- Skills for Advocacy -->
    <details class="mb-6 group border border-gray-200 rounded-lg">
      <summary class="flex items-center justify-between p-4 cursor-pointer font-heading font-semibold text-text-primary hover:bg-gray-50 rounded-lg">
        <span>2. Cross-Functional Skills</span>
        <svg class="w-4 h-4 text-text-secondary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </summary>
      <div class="px-4 pb-4">
        <p class="text-text-secondary leading-relaxed mb-4">Reform rarely succeeds through legal skill alone, or community organising alone, or research alone. A strong coalition needs:</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">
          <div class="rounded-lg border border-gray-200 p-3"><p class="font-semibold text-sm">Legal Advocacy</p><p class="text-xs text-text-secondary mt-1">Constitutional litigation, amicus briefs, regulatory submissions</p></div>
          <div class="rounded-lg border border-gray-200 p-3"><p class="font-semibold text-sm">Policy Analysis</p><p class="text-xs text-text-secondary mt-1">Bill analysis, budget analysis, comparative research</p></div>
          <div class="rounded-lg border border-gray-200 p-3"><p class="font-semibold text-sm">Community Organising</p><p class="text-xs text-text-secondary mt-1">Base-building, popular education, collective action</p></div>
          <div class="rounded-lg border border-gray-200 p-3"><p class="font-semibold text-sm">Research &amp; Evidence</p><p class="text-xs text-text-secondary mt-1">Documenting abuses, building the evidence base, countering narratives</p></div>
          <div class="rounded-lg border border-gray-200 p-3"><p class="font-semibold text-sm">Parliamentary Monitoring</p><p class="text-xs text-text-secondary mt-1">Committee tracking, legislative pipeline, holding MPs accountable</p></div>
          <div class="rounded-lg border border-gray-200 p-3"><p class="font-semibold text-sm">Budget &amp; Finance</p><p class="text-xs text-text-secondary mt-1">Public finance analysis, PAIA requests, audit analysis</p></div>
          <div class="rounded-lg border border-gray-200 p-3"><p class="font-semibold text-sm">Communications &amp; Narrative</p><p class="text-xs text-text-secondary mt-1">Media relations, storytelling, campaign design, framing</p></div>
          <div class="rounded-lg border border-gray-200 p-3"><p class="font-semibold text-sm">Digital Security</p><p class="text-xs text-text-secondary mt-1">Data protection, encrypted comms, breach response</p></div>
        </div>
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 text-sm">
          <p class="font-semibold text-amber-800">Three capability gaps that most frequently limit effectiveness:</p>
          <ol class="text-amber-900 mt-2 space-y-1 list-decimal pl-5">
            <li><strong>Budget literacy</strong> — every coalition needs someone who can read a departmental budget and track MTEF allocations.</li>
            <li><strong>Parliamentary procedure</strong> — knowing when and how to make submissions and engage committees pays enormous dividends.</li>
            <li><strong>Digital security</strong> — organisations working on sensitive JCPS issues face real risks of surveillance and data breaches.</li>
          </ol>
        </div>
      </div>
    </details>

    <!-- Advocacy Ladder -->
    <details class="mb-6 group border border-gray-200 rounded-lg">
      <summary class="flex items-center justify-between p-4 cursor-pointer font-heading font-semibold text-text-primary hover:bg-gray-50 rounded-lg">
        <span>3. The Advocacy Ladder</span>
        <svg class="w-4 h-4 text-text-secondary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </summary>
      <div class="px-4 pb-4">
        <p class="text-text-secondary leading-relaxed mb-4">Start with collaborative engagement and escalate as needed when government fails to respond:</p>
        <div class="space-y-3">
          <div class="flex items-start gap-3 p-3 rounded-lg bg-emerald-50 border border-emerald-200">
            <span class="shrink-0 w-7 h-7 rounded-full bg-emerald-600 text-white font-heading font-bold text-xs flex items-center justify-center">1</span>
            <div><p class="font-semibold text-sm">Constructive Engagement</p><p class="text-xs text-text-secondary mt-0.5">Technical assistance, joint planning, policy dialogue, capacity building with government</p></div>
          </div>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-blue-50 border border-blue-200">
            <span class="shrink-0 w-7 h-7 rounded-full bg-blue-600 text-white font-heading font-bold text-xs flex items-center justify-center">2</span>
            <div><p class="font-semibold text-sm">Evidence-Based Monitoring</p><p class="text-xs text-text-secondary mt-0.5">Submissions, shadow reports, PAIA requests, Parliamentary monitoring, budget tracking</p></div>
          </div>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-amber-50 border border-amber-200">
            <span class="shrink-0 w-7 h-7 rounded-full bg-amber-600 text-white font-heading font-bold text-xs flex items-center justify-center">3</span>
            <div><p class="font-semibold text-sm">Public Advocacy</p><p class="text-xs text-text-secondary mt-0.5">Media campaigns, public reports, op-eds, petitions, community protests, coalition statements</p></div>
          </div>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-orange-50 border border-orange-200">
            <span class="shrink-0 w-7 h-7 rounded-full bg-orange-600 text-white font-heading font-bold text-xs flex items-center justify-center">4</span>
            <div><p class="font-semibold text-sm">Strategic Litigation</p><p class="text-xs text-text-secondary mt-0.5">Constitutional Court applications, High Court review, amicus briefs, interdicts</p></div>
          </div>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-red-50 border border-red-200">
            <span class="shrink-0 w-7 h-7 rounded-full bg-red-600 text-white font-heading font-bold text-xs flex items-center justify-center">5</span>
            <div><p class="font-semibold text-sm">Escalated Mobilisation</p><p class="text-xs text-text-secondary mt-0.5">Mass mobilisation, international pressure, UN mechanisms, full public exposure campaigns</p></div>
          </div>
        </div>
        <p class="text-xs text-text-secondary mt-3 italic">The ladder is not linear — you may operate at multiple levels simultaneously.</p>
      </div>
    </details>

    <!-- JCPS Reform Priorities -->
    <details class="mb-6 group border border-gray-200 rounded-lg">
      <summary class="flex items-center justify-between p-4 cursor-pointer font-heading font-semibold text-text-primary hover:bg-gray-50 rounded-lg">
        <span>4. JCPS Reform Priorities</span>
        <svg class="w-4 h-4 text-text-secondary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </summary>
      <div class="px-4 pb-4 space-y-4">
        <div>
          <h4 class="font-heading font-semibold text-sm text-text-primary mb-1">Justice &amp; Constitutional Development</h4>
          <ul class="text-text-secondary text-sm space-y-1 list-disc pl-5">
            <li>Court backlogs and access to justice — virtual courts, additional magistrates, diversion programmes</li>
            <li>Legal aid coverage gaps and funding</li>
            <li>Gender justice — Domestic Violence Act implementation, dedicated GBV courts</li>
            <li>Anti-corruption — NPA accountability, SIU referral pipeline, asset forfeiture</li>
          </ul>
        </div>
        <div>
          <h4 class="font-heading font-semibold text-sm text-text-primary mb-1">Correctional Services</h4>
          <ul class="text-text-secondary text-sm space-y-1 list-disc pl-5">
            <li>Prison conditions and overcrowding — JICS oversight visits, constitutional litigation</li>
            <li>Remand detention — Section 35 rights violations, data publication</li>
            <li>Rehabilitation programmes — TVET, education, psychosocial support</li>
            <li>Parole and reintegration — board functioning, unlawful detention beyond sentence</li>
          </ul>
        </div>
        <div>
          <h4 class="font-heading font-semibold text-sm text-text-primary mb-1">Police — Safety &amp; Security</h4>
          <ul class="text-text-secondary text-sm space-y-1 list-disc pl-5">
            <li>Police accountability — IPID referrals, consequence management</li>
            <li>GBVF response — Thuthuzela Care Centres, response times</li>
            <li>Community policing forums — civil society representation, transparent funding</li>
            <li>Protest and assembly rights — monitoring excessive force</li>
          </ul>
        </div>
        <div>
          <h4 class="font-heading font-semibold text-sm text-text-primary mb-1">Cross-Cutting Priorities</h4>
          <ul class="text-text-secondary text-sm space-y-1 list-disc pl-5">
            <li>GBVF National Strategic Plan — unified scorecard across all four departments</li>
            <li>Data transparency — systematic PAIA programme</li>
            <li>Budget accountability — shadow departmental budgets every year</li>
          </ul>
        </div>
      </div>
    </details>

    <!-- Key Oversight Bodies -->
    <details class="mb-6 group border border-gray-200 rounded-lg">
      <summary class="flex items-center justify-between p-4 cursor-pointer font-heading font-semibold text-text-primary hover:bg-gray-50 rounded-lg">
        <span>5. Key Oversight Bodies</span>
        <svg class="w-4 h-4 text-text-secondary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </summary>
      <div class="px-4 pb-4">
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead><tr class="bg-gray-50"><th class="text-left p-2 font-heading font-semibold border-b">Body</th><th class="text-left p-2 font-heading font-semibold border-b">Mandate</th><th class="text-left p-2 font-heading font-semibold border-b">How Civil Society Engages</th></tr></thead>
            <tbody>
              <tr class="border-b"><td class="p-2 font-semibold">IPID</td><td class="p-2">Investigate police misconduct</td><td class="p-2">Report cases; monitor investigations; submit research on patterns</td></tr>
              <tr class="border-b"><td class="p-2 font-semibold">JICS</td><td class="p-2">Inspect correctional centres</td><td class="p-2">Share evidence; conduct joint oversight visits</td></tr>
              <tr class="border-b"><td class="p-2 font-semibold">SAHRC</td><td class="p-2">Investigate rights violations</td><td class="p-2">Submit complaints; partner on investigations</td></tr>
              <tr class="border-b"><td class="p-2 font-semibold">Public Protector</td><td class="p-2">Investigate maladministration</td><td class="p-2">Submit complaints on systematic failures</td></tr>
              <tr class="border-b"><td class="p-2 font-semibold">Auditor-General</td><td class="p-2">Audit financial and performance management</td><td class="p-2">Engage on findings; submit evidence of misreporting</td></tr>
              <tr><td class="p-2 font-semibold">SCOPA</td><td class="p-2">Hold departments accountable for audits</td><td class="p-2">Submit briefs ahead of hearings</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </details>

    <!-- First 90 Days -->
    <details class="mb-6 group border border-gray-200 rounded-lg">
      <summary class="flex items-center justify-between p-4 cursor-pointer font-heading font-semibold text-text-primary hover:bg-gray-50 rounded-lg">
        <span>6. Getting Started — First 90 Days</span>
        <svg class="w-4 h-4 text-text-secondary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </summary>
      <div class="px-4 pb-4">
        <div class="space-y-4">
          <div class="border-l-4 border-emerald-500 pl-4">
            <p class="font-heading font-semibold text-sm">Days 1–30: Convening &amp; Charter</p>
            <ul class="text-text-secondary text-xs mt-1 space-y-0.5 list-disc pl-4">
              <li>Identify 3–7 founding organisations with diverse strengths</li>
              <li>Hold founding meeting focused on shared values and theory of change</li>
              <li>Draft and finalise a Coalition Charter</li>
              <li>Designate a Convenor Organisation for year one</li>
            </ul>
          </div>
          <div class="border-l-4 border-blue-500 pl-4">
            <p class="font-heading font-semibold text-sm">Days 31–60: Skills, Structure &amp; Strategy</p>
            <ul class="text-text-secondary text-xs mt-1 space-y-0.5 list-disc pl-4">
              <li>Complete a coalition-wide Skills Audit</li>
              <li>Form Thematic Working Groups around priority reform areas</li>
              <li>Draft your Theory of Change for each priority</li>
              <li>Submit your first joint work to a Portfolio Committee</li>
            </ul>
          </div>
          <div class="border-l-4 border-amber-500 pl-4">
            <p class="font-heading font-semibold text-sm">Days 61–90: First Public Actions</p>
            <ul class="text-text-secondary text-xs mt-1 space-y-0.5 list-disc pl-4">
              <li>Publish a "State of the System" statement</li>
              <li>Hold your first community consultation event</li>
              <li>Attend a Portfolio Committee hearing</li>
              <li>Launch public presence: website, social media, first newsletter</li>
            </ul>
          </div>
        </div>
      </div>
    </details>
  </section>

  <!-- ===================== PROVINCIAL PANEL ===================== -->
  <section
    id="panel-provincial"
    role="tabpanel"
    aria-labelledby="tab-provincial"
    class="playbook-panel hidden"
    data-panel="provincial"
  >
    <!-- Download banner -->
    <div class="rounded-lg border border-blue-200 bg-blue-50 p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-8">
      <div>
        <p class="font-heading font-semibold text-text-primary text-sm">Changing the System From Outside It — Education Reform Playbook</p>
        <p class="text-text-secondary text-xs mt-0.5">Basic Education reform across all nine provinces</p>
      </div>
      <a
        href="/downloads/Education_Reform_Advocacy_Playbook.pdf"
        download
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 text-white font-heading text-sm font-semibold hover:bg-blue-700 transition-colors shrink-0"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" /></svg>
        Download Full Playbook (PDF)
      </a>
    </div>

    <!-- Why This Playbook -->
    <div class="mb-10">
      <h2 class="font-heading text-2xl font-bold text-text-primary mb-3">Why This Playbook Exists</h2>
      <p class="text-text-secondary leading-relaxed mb-3">
        Government cannot fix a broken education system alone — not because officials lack ability, but because fixing it requires pressure from the outside, voice from communities, evidence from independent researchers, and legal accountability through courts and commissions. Civil society provides all four.
      </p>
      <p class="text-text-secondary leading-relaxed">
        South Africa's Constitution places Basic Education in <strong class="text-text-primary">Schedule 4 as a concurrent national and provincial function</strong>. The DBE writes policy; nine Provincial Education Departments deliver it. This split creates a gap between policy intent and classroom reality that civil society is uniquely positioned to fill.
      </p>
    </div>

    <!-- The Gap Civil Society Fills -->
    <details class="mb-6 group border border-gray-200 rounded-lg" open>
      <summary class="flex items-center justify-between p-4 cursor-pointer font-heading font-semibold text-text-primary hover:bg-gray-50 rounded-lg">
        <span>1. The Gap Civil Society Fills</span>
        <svg class="w-4 h-4 text-text-secondary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </summary>
      <div class="px-4 pb-4">
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead><tr class="bg-gray-50"><th class="text-left p-2 font-heading font-semibold border-b">Government Blind Spot</th><th class="text-left p-2 font-heading font-semibold border-b">CSO Advantage</th></tr></thead>
            <tbody>
              <tr class="border-b"><td class="p-2">EMIS shows enrolment, not learning quality</td><td class="p-2">School-level research, learner testimony, NGO field presence</td></tr>
              <tr class="border-b"><td class="p-2">PERSAL tracks posts, not teacher wellbeing</td><td class="p-2">Union partnerships, teacher communities of practice</td></tr>
              <tr class="border-b"><td class="p-2">Infrastructure plans driven by assets, not lived experience</td><td class="p-2">Community-based organisations, ward committees, parent networks</td></tr>
              <tr class="border-b"><td class="p-2">Departments litigate to defend decisions</td><td class="p-2">Public interest litigation, constitutional rights monitoring</td></tr>
              <tr><td class="p-2">Treasury reports on expenditure, not impact</td><td class="p-2">Budget monitoring NGOs, Auditor-General shadow reports</td></tr>
            </tbody>
          </table>
        </div>
        <h4 class="font-heading font-semibold text-text-primary mt-5 mb-2">Civil Society is Not a Monolith</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
          <div class="p-2 rounded bg-blue-50"><strong>Rights-based NGOs</strong> — legal and constitutional power</div>
          <div class="p-2 rounded bg-blue-50"><strong>Research institutions</strong> — evidence and credibility</div>
          <div class="p-2 rounded bg-blue-50"><strong>Community-based organisations</strong> — legitimacy and reach</div>
          <div class="p-2 rounded bg-blue-50"><strong>Teacher organisations</strong> — labour and professional power</div>
          <div class="p-2 rounded bg-blue-50"><strong>Media</strong> — narrative and public pressure</div>
          <div class="p-2 rounded bg-blue-50"><strong>Philanthropic foundations</strong> — funding and convening</div>
          <div class="p-2 rounded bg-blue-50"><strong>Faith communities</strong> — trust and local infrastructure</div>
          <div class="p-2 rounded bg-blue-50"><strong>Student &amp; youth formations</strong> — moral authority and mobilisation</div>
        </div>
      </div>
    </details>

    <!-- Coalition Architecture -->
    <details class="mb-6 group border border-gray-200 rounded-lg">
      <summary class="flex items-center justify-between p-4 cursor-pointer font-heading font-semibold text-text-primary hover:bg-gray-50 rounded-lg">
        <span>2. Coalition Architecture</span>
        <svg class="w-4 h-4 text-text-secondary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </summary>
      <div class="px-4 pb-4">
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead><tr class="bg-gray-50"><th class="text-left p-2 font-heading font-semibold border-b">Layer</th><th class="text-left p-2 font-heading font-semibold border-b">Body</th><th class="text-left p-2 font-heading font-semibold border-b">Role</th></tr></thead>
            <tbody>
              <tr class="border-b"><td class="p-2 font-semibold">Strategic</td><td class="p-2">Coalition Steering Group (10–15 members)</td><td class="p-2">Sets direction, approves mandates, manages positioning. Meets quarterly.</td></tr>
              <tr class="border-b"><td class="p-2 font-semibold">Operational</td><td class="p-2">Campaign Coordination Team (5–7 people)</td><td class="p-2">Day-to-day management, shared calendar, workplans. Meets weekly.</td></tr>
              <tr class="border-b"><td class="p-2 font-semibold">Execution</td><td class="p-2">Campaign Working Groups (4–8 per issue)</td><td class="p-2">Issue-specific teams owning campaigns from diagnosis to win.</td></tr>
              <tr><td class="p-2 font-semibold">Anchor</td><td class="p-2">Coalition Secretariat (rotates every 2 years)</td><td class="p-2">Legal home, banking, HR, admin infrastructure.</td></tr>
