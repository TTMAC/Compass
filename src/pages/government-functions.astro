---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="SA Government Functions — GovCompass"
  description="A MECE framework mapping all functional areas across South Africa's three spheres of government — National, Provincial and Municipal — as defined by the Constitution."
>
  <style>
    .gf-root {
      --bg: #f5f0e8;
      --bg-card: #ffffff;
      --text: #1a1a1a;
      --text-muted: #5a5a5a;
      --accent-national: #1b4332;
      --accent-national-light: #d8f3dc;
      --accent-provincial: #14213d;
      --accent-provincial-light: #d6e4f0;
      --accent-municipal: #6b2737;
      --accent-municipal-light: #f2d7dd;
      --accent-concurrent: #7b5e00;
      --accent-concurrent-light: #fff3c4;
      --border: #d4cfc4;
      --shadow: 0 2px 12px rgba(0,0,0,0.06);
      --radius: 10px;
    }

    .gf-root {
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      line-height: 1.6;
      font-size: 15px;
    }

    .gf-hero {
      background: var(--accent-national);
      color: white;
      padding: 48px 32px 40px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .gf-hero::before {
      content: '';
      position: absolute;
      top: -60%;
      left: -20%;
      width: 140%;
      height: 200%;
      background: radial-gradient(ellipse at 30% 40%, rgba(255,255,255,0.06) 0%, transparent 60%);
      pointer-events: none;
    }
    .gf-hero h1 {
      font-family: 'Fraunces', serif;
      font-weight: 800;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      letter-spacing: -0.5px;
      margin-bottom: 8px;
      position: relative;
    }
    .gf-hero .gf-flag {
      display: inline-flex;
      gap: 3px;
      margin-bottom: 16px;
    }
    .gf-hero .gf-flag span {
      width: 20px;
      height: 6px;
      border-radius: 3px;
      display: inline-block;
    }
    .gf-hero .gf-subtitle {
      font-size: 0.95rem;
      opacity: 0.8;
      max-width: 640px;
      margin: 0 auto;
      line-height: 1.5;
    }

    .gf-nav-tabs {
      display: flex;
      justify-content: center;
      gap: 8px;
      padding: 20px 16px 0;
      flex-wrap: wrap;
      position: sticky;
      top: 0;
      background: var(--bg);
      z-index: 100;
      border-bottom: 1px solid var(--border);
      padding-bottom: 16px;
    }
    .gf-nav-tabs button {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.82rem;
      font-weight: 500;
      padding: 8px 18px;
      border: 1.5px solid var(--border);
      border-radius: 24px;
      background: var(--bg-card);
      color: var(--text-muted);
      cursor: pointer;
      transition: all 0.25s;
    }
    .gf-nav-tabs button:hover { border-color: #999; }
    .gf-nav-tabs button.active {
      background: var(--accent-national);
      color: white;
      border-color: var(--accent-national);
    }
    .gf-nav-tabs button[data-tab="concurrent"].active { background: var(--accent-concurrent); border-color: var(--accent-concurrent); }
    .gf-nav-tabs button[data-tab="national"].active { background: var(--accent-national); border-color: var(--accent-national); }
    .gf-nav-tabs button[data-tab="provincial"].active { background: var(--accent-provincial); border-color: var(--accent-provincial); }
    .gf-nav-tabs button[data-tab="municipal"].active { background: var(--accent-municipal); border-color: var(--accent-municipal); }

    .gf-container { max-width: 1100px; margin: 0 auto; padding: 24px 16px 60px; }

    .gf-tab-content { display: none; animation: gfFadeIn 0.3s ease; }
    .gf-tab-content.active { display: block; }
    @keyframes gfFadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

    .gf-section-intro {
      background: var(--bg-card);
      border-radius: var(--radius);
      padding: 24px 28px;
      margin-bottom: 24px;
      border-left: 4px solid var(--accent-national);
      box-shadow: var(--shadow);
    }
    .gf-section-intro[data-type="concurrent"] { border-left-color: var(--accent-concurrent); }
    .gf-section-intro[data-type="provincial"] { border-left-color: var(--accent-provincial); }
    .gf-section-intro[data-type="municipal"] { border-left-color: var(--accent-municipal); }
    .gf-section-intro h2 {
      font-family: 'Fraunces', serif;
      font-weight: 600;
      font-size: 1.35rem;
      margin-bottom: 8px;
    }
    .gf-section-intro p { color: var(--text-muted); font-size: 0.9rem; }

    .gf-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; }

    .gf-card {
      background: var(--bg-card);
      border-radius: var(--radius);
      padding: 20px 22px;
      box-shadow: var(--shadow);
      border-top: 3px solid var(--accent-national);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .gf-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.08); }
    .gf-card[data-type="concurrent"] { border-top-color: var(--accent-concurrent); }
    .gf-card[data-type="provincial"] { border-top-color: var(--accent-provincial); }
    .gf-card[data-type="municipal"] { border-top-color: var(--accent-municipal); }

    .gf-card h3 {
      font-family: 'Fraunces', serif;
      font-weight: 600;
      font-size: 1.05rem;
      margin-bottom: 6px;
    }
    .gf-card .gf-dept {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 3px 10px;
      border-radius: 12px;
      margin-bottom: 10px;
    }
    .gf-card[data-type="national"] .gf-dept { background: var(--accent-national-light); color: var(--accent-national); }
    .gf-card[data-type="concurrent"] .gf-dept { background: var(--accent-concurrent-light); color: var(--accent-concurrent); }
    .gf-card[data-type="provincial"] .gf-dept { background: var(--accent-provincial-light); color: var(--accent-provincial); }
    .gf-card[data-type="municipal"] .gf-dept { background: var(--accent-municipal-light); color: var(--accent-municipal); }

    .gf-card .gf-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.55; }

    .gf-legend {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
      margin: 20px 0 8px;
      font-size: 0.78rem;
      color: var(--text-muted);
    }
    .gf-legend-item { display: flex; align-items: center; gap: 6px; }
    .gf-legend-dot { width: 10px; height: 10px; border-radius: 50%; }

    .gf-overview-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      background: var(--bg-card);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
      margin-top: 16px;
      font-size: 0.85rem;
    }
    .gf-overview-table th {
      background: var(--accent-national);
      color: white;
      padding: 12px 16px;
      text-align: left;
      font-weight: 500;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .gf-overview-table td {
      padding: 10px 16px;
      border-bottom: 1px solid #eee;
      vertical-align: top;
    }
    .gf-overview-table tr:last-child td { border-bottom: none; }
    .gf-overview-table tr:hover td { background: #faf8f4; }
    .gf-badge {
      display: inline-block;
      font-size: 0.7rem;
      padding: 2px 8px;
      border-radius: 10px;
      font-weight: 500;
    }
    .gf-badge-exc-nat { background: var(--accent-national-light); color: var(--accent-national); }
    .gf-badge-conc { background: var(--accent-concurrent-light); color: var(--accent-concurrent); }
    .gf-badge-exc-prov { background: var(--accent-provincial-light); color: var(--accent-provincial); }
    .gf-badge-muni { background: var(--accent-municipal-light); color: var(--accent-municipal); }

    .gf-note-box {
      background: #fff9e6;
      border: 1px solid #f0e0a0;
      border-radius: var(--radius);
      padding: 16px 20px;
      margin-top: 20px;
      font-size: 0.83rem;
      color: #6b5800;
    }
    .gf-note-box strong { color: #4a3d00; }

    @media(max-width: 600px) {
      .gf-grid { grid-template-columns: 1fr; }
      .gf-hero { padding: 32px 20px; }
      .gf-container { padding: 16px 12px 40px; }
      .gf-overview-table { font-size: 0.78rem; }
      .gf-overview-table th, .gf-overview-table td { padding: 8px 10px; }
    }
  </style>

  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,500;0,9..40,700;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,600;0,9..144,800;1,9..144,400&display=swap" rel="stylesheet" slot="head" />

  <div class="gf-root">
    <div class="gf-hero">
      <div class="gf-flag">
        <span style="background:#DE3831"></span>
        <span style="background:#FFFFFF"></span>
        <span style="background:#007A4D"></span>
        <span style="background:#002395"></span>
        <span style="background:#FFB612"></span>
        <span style="background:#000000"></span>
      </div>
      <h1>South African Government Functions</h1>
      <p class="gf-subtitle">A comprehensive framework mapping all functional areas across the three spheres of government — National, Provincial and Municipal — as defined by Schedules 4 &amp; 5 of the Constitution (Act 108 of 1996), including Concurrent, Exclusive, and the responsible departments.</p>
    </div>

    <div class="gf-legend">
      <div class="gf-legend-item"><div class="gf-legend-dot" style="background:var(--accent-national)"></div> Exclusive National</div>
      <div class="gf-legend-item"><div class="gf-legend-dot" style="background:var(--accent-concurrent)"></div> Concurrent (Schedule 4)</div>
      <div class="gf-legend-item"><div class="gf-legend-dot" style="background:var(--accent-provincial)"></div> Exclusive Provincial (Schedule 5)</div>
      <div class="gf-legend-item"><div class="gf-legend-dot" style="background:var(--accent-municipal)"></div> Local Government</div>
    </div>

    <nav class="gf-nav-tabs" aria-label="Government functions categories">
      <button class="active" data-tab="overview">Overview Matrix</button>
      <button data-tab="national">Exclusive National</button>
      <button data-tab="concurrent">Concurrent (Sch 4)</button>
      <button data-tab="provincial">Exclusive Provincial (Sch 5)</button>
      <button data-tab="municipal">Municipal Functions</button>
    </nav>

    <div class="gf-container">

      <!-- OVERVIEW TAB -->
      <div class="gf-tab-content active" id="gf-tab-overview">
        <div class="gf-section-intro">
          <h2>Constitutional Allocation of Functions</h2>
          <p>The 1996 Constitution creates three distinctive, interdependent and interrelated spheres. Functions are allocated via <strong>Schedule 4</strong> (concurrent national &amp; provincial competence) and <strong>Schedule 5</strong> (exclusive provincial competence). Each schedule is subdivided into <strong>Part A</strong> (national/provincial domain) and <strong>Part B</strong> (local government matters). Functions <em>not listed</em> in either schedule fall within <strong>exclusive national competence</strong> by residual power.</p>
        </div>

        <table class="gf-overview-table">
          <thead>
            <tr>
              <th style="width:30%">Functional Area</th>
              <th style="width:15%">Competence Zone</th>
              <th style="width:20%">Schedule / Part</th>
              <th style="width:35%">Key Responsible Department(s)</th>
            </tr>
          </thead>
          <tbody>
            <!-- EXCLUSIVE NATIONAL -->
            <tr><td>Defence &amp; Military Veterans</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual (not in Sch 4/5)</td><td>Dept of Defence &amp; Military Veterans</td></tr>
            <tr><td>Foreign Affairs &amp; International Relations</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual</td><td>Dept of International Relations &amp; Cooperation (DIRCO)</td></tr>
            <tr><td>Home Affairs &amp; Immigration</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual</td><td>Dept of Home Affairs</td></tr>
            <tr><td>National Treasury &amp; Fiscal Policy</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual / Ch 13</td><td>National Treasury; SA Reserve Bank</td></tr>
            <tr><td>Higher Education &amp; Tertiary Education</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual (Sch 4 excludes tertiary)</td><td>Dept of Higher Education &amp; Training</td></tr>
            <tr><td>Justice &amp; Constitutional Development</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual / Ch 8</td><td>Dept of Justice &amp; Constitutional Development</td></tr>
            <tr><td>Correctional Services</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual / Ch 11</td><td>Dept of Correctional Services</td></tr>
            <tr><td>Intelligence Services</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual / Ch 11</td><td>State Security Agency</td></tr>
            <tr><td>Telecommunications &amp; ICT</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual</td><td>Dept of Communications &amp; Digital Technologies</td></tr>
            <tr><td>Energy &amp; Minerals</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual</td><td>Dept of Mineral Resources &amp; Energy</td></tr>
            <tr><td>Water &amp; Sanitation (bulk/strategic)</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual</td><td>Dept of Water &amp; Sanitation</td></tr>
            <tr><td>National Parks, Botanical Gardens &amp; Marine Resources</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Excluded from Sch 4</td><td>Dept of Forestry, Fisheries &amp; the Environment</td></tr>
            <tr><td>International &amp; National Shipping</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Excluded from Sch 4</td><td>Dept of Transport</td></tr>
            <tr><td>National Roads &amp; Transport Regulation</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual</td><td>Dept of Transport; SANRAL</td></tr>
            <tr><td>Land Reform &amp; Rural Development</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual</td><td>Dept of Agriculture, Land Reform &amp; Rural Development</td></tr>
            <tr><td>Labour Relations &amp; Employment</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual</td><td>Dept of Employment &amp; Labour</td></tr>
            <tr><td>Science, Technology &amp; Innovation</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual</td><td>Dept of Science &amp; Innovation</td></tr>
            <tr><td>National Lotteries &amp; Sports Pools</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Excluded from Sch 4</td><td>Dept of Sport, Arts &amp; Culture</td></tr>
            <tr><td>Public Enterprises (SOCs/SOEs)</td><td><span class="gf-badge gf-badge-exc-nat">Exclusive National</span></td><td>Residual</td><td>Dept of Public Enterprises</td></tr>

            <!-- CONCURRENT -->
            <tr><td>Agriculture</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Agriculture / Provincial Depts of Agriculture</td></tr>
            <tr><td>Education (all levels excl. tertiary)</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Basic Education / Provincial Education Depts</td></tr>
            <tr><td>Health Services</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Health / Provincial Health Depts</td></tr>
            <tr><td>Housing</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Human Settlements / Provincial HS Depts</td></tr>
            <tr><td>Police (to extent of Ch 11)</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Police / Provincial Community Safety</td></tr>
            <tr><td>Environment</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Forestry, Fisheries &amp; Environment / Provincial DFFE</td></tr>
            <tr><td>Disaster Management</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Cooperative Governance / Provincial CoGTA</td></tr>
            <tr><td>Consumer Protection</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Trade, Industry &amp; Competition</td></tr>
            <tr><td>Tourism</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Tourism / Provincial Tourism</td></tr>
            <tr><td>Trade</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Trade, Industry &amp; Competition</td></tr>
            <tr><td>Nature Conservation (excl. national parks)</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of DFFE / Provincial Conservation</td></tr>
            <tr><td>Welfare Services</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Social Development / Provincial DSD</td></tr>
            <tr><td>Cultural Matters</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Sport, Arts &amp; Culture / Provincial Arts</td></tr>
            <tr><td>Industrial Promotion</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Trade, Industry &amp; Competition</td></tr>
            <tr><td>Language Policy &amp; Official Languages</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Sport, Arts &amp; Culture / PanSALB</td></tr>
            <tr><td>Indigenous Law &amp; Customary Law</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Justice / Dept of CoGTA (Traditional Affairs)</td></tr>
            <tr><td>Traditional Leadership</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of CoGTA / Provincial Houses of Traditional Leaders</td></tr>
            <tr><td>Urban &amp; Rural Development</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of CoGTA / Provincial Planning</td></tr>
            <tr><td>Regional Planning &amp; Development</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of CoGTA / Provincial Planning</td></tr>
            <tr><td>Public Works (provincial needs)</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Public Works &amp; Infrastructure</td></tr>
            <tr><td>Road Traffic Regulation</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Transport / Provincial Transport</td></tr>
            <tr><td>Airports (non-international/national)</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Transport / Provincial Transport</td></tr>
            <tr><td>Animal Control &amp; Diseases</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Agriculture / Provincial Agriculture</td></tr>
            <tr><td>Casinos, Racing, Gambling &amp; Wagering</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Trade, Industry &amp; Competition / Provincial Gambling Boards</td></tr>
            <tr><td>Indigenous Forests Administration</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Forestry, Fisheries &amp; Environment</td></tr>
            <tr><td>Media Services (provincial)</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Provincial Media Services</td></tr>
            <tr><td>Pollution Control</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of DFFE / Provincial DFFE</td></tr>
            <tr><td>Population Development</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Social Development</td></tr>
            <tr><td>Property Transfer Fees</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>National Treasury / Provincial Treasury</td></tr>
            <tr><td>Soil Conservation</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Agriculture</td></tr>
            <tr><td>Vehicle Licensing</td><td><span class="gf-badge gf-badge-conc">Concurrent</span></td><td>Sch 4 Part A</td><td>Dept of Transport / Provincial Transport</td></tr>

            <!-- EXCLUSIVE PROVINCIAL -->
            <tr><td>Abattoirs</td><td><span class="gf-badge gf-badge-exc-prov">Exclusive Provincial</span></td><td>Sch 5 Part A</td><td>Provincial Agriculture Depts</td></tr>
            <tr><td>Ambulance Services</td><td><span class="gf-badge gf-badge-exc-prov">Exclusive Provincial</span></td><td>Sch 5 Part A</td><td>Provincial Health Depts</td></tr>
            <tr><td>Archives (non-national)</td><td><span class="gf-badge gf-badge-exc-prov">Exclusive Provincial</span></td><td>Sch 5 Part A</td><td>Provincial Arts &amp; Culture Depts</td></tr>
            <tr><td>Libraries (non-national)</td><td><span class="gf-badge gf-badge-exc-prov">Exclusive Provincial</span></td><td>Sch 5 Part A</td><td>Provincial Arts &amp; Culture Depts</td></tr>
            <tr><td>Liquor Licences</td><td><span class="gf-badge gf-badge-exc-prov">Exclusive Provincial</span></td><td>Sch 5 Part A</td><td>Provincial Liquor Authorities</td></tr>
            <tr><td>Museums (non-national)</td><td><span class="gf-badge gf-badge-exc-prov">Exclusive Provincial</span></td><td>Sch 5 Part A</td><td>Provincial Arts &amp; Culture Depts</td></tr>
            <tr><td>Provincial Planning</td><td><span class="gf-badge gf-badge-exc-prov">Exclusive Provincial</span></td><td>Sch 5 Part A</td><td>Provincial Planning Commissions / Premier's Office</td></tr>
            <tr><td>Provincial Cultural Matters</td><td><span class="gf-badge gf-badge-exc-prov">Exclusive Provincial</span></td><td>Sch 5 Part A</td><td>Provincial Arts &amp; Culture Depts</td></tr>
