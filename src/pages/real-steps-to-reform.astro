<script>
  // ── Workstream filtering ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".reform-filter-btn");
  const wsSections = document.querySelectorAll<HTMLElement>(".reform-ws-section");
  const wsTimelineRows = document.querySelectorAll<HTMLElement>(".reform-ws-row");
  const phaseSections = document.querySelectorAll<HTMLElement>(".reform-phase-section");
  const reformCards = document.querySelectorAll<HTMLElement>(".reform-card");
  const indicator = document.getElementById("active-filter-indicator")!;
  const indicatorText = document.getElementById("active-filter-text")!;
  const clearBtn = document.getElementById("clear-phase-filter")!;
  const searchInput = document.getElementById("reform-search") as HTMLInputElement;
  const reformCountEl = document.getElementById("reform-count")!;
  const emptyState = document.getElementById("reform-empty-state")!;
  const emptyDetail = document.getElementById("reform-empty-detail")!;
  const clearAllBtn = document.getElementById("reform-clear-all")!;
  const totalReforms = reformCards.length;

  let activeWorkstream = "all";
  let activePhase = "";
  let searchQuery = "";

  const validWorkstreams = new Set<string>(
    Array.from(filterBtns).map((b) => b.dataset.filter!),
  );
  const validPhases = new Set<string>(
    Array.from(document.querySelectorAll<HTMLButtonElement>(".reform-phase-btn"))
      .map((b) => b.dataset.phase!),
  );

  function setWorkstreamButtonStyles(filter: string) {
    filterBtns.forEach((b) => {
      const isActive = b.dataset.filter === filter;
      b.setAttribute("aria-pressed", String(isActive));
      if (isActive) {
        if (filter === "all") {
          b.style.cssText = "border-color: #355E3B; background-color: #355E3B; color: white";
        } else {
          b.style.cssText = `border-color: ${b.dataset.color}; background-color: ${b.dataset.color}; color: white`;
        }
      } else {
        if (b.dataset.filter === "all") {
          b.style.cssText = "border-color: #355E3B; background-color: transparent; color: #355E3B";
        } else {
          b.style.cssText = `border-color: ${b.dataset.color}; background-color: transparent; color: ${b.dataset.color}`;
        }
      }
    });
  }

  function syncUrl() {
    const params = new URLSearchParams();
    if (activeWorkstream !== "all") params.set("ws", activeWorkstream);
    if (activePhase) params.set("phase", activePhase);
    if (searchQuery) params.set("q", searchQuery);
    const qs = params.toString();
    const newUrl = `${window.location.pathname}${qs ? "?" + qs : ""}${window.location.hash}`;
    window.history.replaceState(null, "", newUrl);
  }

  function applyFilters() {
    const query = searchQuery.toLowerCase();
    let visibleCount = 0;

    // Filter individual reform cards
    reformCards.forEach((card) => {
      const ws = card.dataset.workstream!;
      const ph = card.dataset.phase!;
      const wsMatch = activeWorkstream === "all" || activeWorkstream === ws;
      const phMatch = !activePhase || activePhase === ph;
      const textMatch = !query || card.textContent!.toLowerCase().includes(query);
      const visible = wsMatch && phMatch && textMatch;
      card.style.display = visible ? "" : "none";
      if (visible) visibleCount++;
    });

    // Hide empty phase sections (all cards hidden)
    phaseSections.forEach((s) => {
      const hasVisible = s.querySelector('.reform-card:not([style*="display: none"])');
      const ws = s.dataset.workstream!;
      const wsMatch = activeWorkstream === "all" || activeWorkstream === ws;
      s.style.display = wsMatch && hasVisible ? "" : "none";
    });

    // Hide empty workstream sections
    wsSections.forEach((s) => {
      const ws = s.dataset.workstream!;
      const wsMatch = activeWorkstream === "all" || activeWorkstream === ws;
      const hasVisible = s.querySelector('.reform-card:not([style*="display: none"])');
      s.style.display = wsMatch && hasVisible ? "" : "none";
    });

    // Timeline rows follow workstream filter only (not search)
    wsTimelineRows.forEach((r) => {
      const ws = r.dataset.workstream!;
      r.style.display = activeWorkstream === "all" || activeWorkstream === ws ? "" : "none";
    });

    // Milestone items follow workstream filter only
    document.querySelectorAll<HTMLElement>(".milestone-item").forEach((item) => {
      const ws = item.dataset.workstream!;
      item.style.display = activeWorkstream === "all" || activeWorkstream === ws ? "" : "none";
    });

    // Reform count
    if (query || activeWorkstream !== "all" || activePhase) {
      reformCountEl.textContent = `${visibleCount} of ${totalReforms} reforms`;
    } else {
      reformCountEl.textContent = `${totalReforms} reforms`;
    }

    // Empty state
    const hasAnyFilter = !!(query || activeWorkstream !== "all" || activePhase);
    if (visibleCount === 0 && hasAnyFilter) {
      emptyState.classList.remove("hidden");
      const parts: string[] = [];
      if (query) parts.push(`search "${query}"`);
      if (activeWorkstream !== "all") {
        const wsBtn = document.querySelector<HTMLButtonElement>(
          `.reform-filter-btn[data-filter="${activeWorkstream}"]`,
        );
        if (wsBtn) parts.push(`workstream ${wsBtn.textContent?.trim()}`);
      }
      if (activePhase) parts.push(activePhase.replace("-", " "));
      emptyDetail.textContent = parts.length
        ? `No reforms match ${parts.join(" + ")}. Try a different filter or clear them all.`
        : "Try a different workstream, phase, or search term.";
    } else {
      emptyState.classList.add("hidden");
    }

    // Phase filter indicator
    if (activePhase) {
      indicator.classList.remove("hidden");
      indicator.classList.add("flex");
      const phaseBtn = document.querySelector<HTMLButtonElement>(
        `.reform-phase-btn[data-phase="${activePhase}"][data-workstream="${activeWorkstream}"]`
      );
      indicatorText.textContent = phaseBtn
        ? `Showing: ${phaseBtn.title}`
        : `Filtered to ${activePhase.replace("-", " ")}`;
    } else {
      indicator.classList.add("hidden");
      indicator.classList.remove("flex");
    }

    syncUrl();
  }

  // Search input
  let searchTimeout: ReturnType<typeof setTimeout>;
  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      searchQuery = searchInput.value.trim();
      applyFilters();
    }, 150);
  });

  // Workstream filter buttons
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;
      activeWorkstream = filter;
      activePhase = ""; // Reset phase filter when switching workstream

      setWorkstreamButtonStyles(filter);

      applyFilters();
    });
  });

  // Phase timeline buttons
  document.querySelectorAll<HTMLButtonElement>(".reform-phase-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const ws = btn.dataset.workstream!;
      const phase = btn.dataset.phase!;

      // If clicking the same phase, toggle it off
      if (activeWorkstream === ws && activePhase === phase) {
        activePhase = "";
      } else {
        // Set workstream filter to match
        if (activeWorkstream !== ws) {
          activeWorkstream = ws;
          setWorkstreamButtonStyles(ws);
        }
        activePhase = phase;
      }

      applyFilters();
    });
  });

  // Clear phase filter
  clearBtn.addEventListener("click", () => {
    activePhase = "";
    applyFilters();
  });

  // Clear all filters (from empty state)
  clearAllBtn.addEventListener("click", () => {
    activeWorkstream = "all";
    activePhase = "";
    searchQuery = "";
    searchInput.value = "";
    setWorkstreamButtonStyles("all");
    applyFilters();
  });

  // Expand all / Collapse all buttons per workstream section
  document.querySelectorAll<HTMLButtonElement>(".reform-expand-all").forEach((btn) => {
    btn.addEventListener("click", () => {
      const ws = btn.dataset.workstream!;
      const action = btn.dataset.action!;
      const shouldOpen = action === "expand";
      document
        .querySelectorAll<HTMLDetailsElement>(`.reform-card[data-workstream="${ws}"]`)
        .forEach((card) => {
          card.open = shouldOpen;
        });
    });
  });

  // Dependency links: open the target reform card so it's visible after anchor scroll
  document.querySelectorAll<HTMLAnchorElement>(".reform-dep-link").forEach((link) => {
    link.addEventListener("click", () => {
      const depId = link.dataset.depId!;
      const target = document.getElementById(`reform-${depId}`) as HTMLDetailsElement | null;
      if (!target) return;

      const targetWs = target.dataset.workstream!;
      const targetPhase = target.dataset.phase!;
      const needsReset =
        (activeWorkstream !== "all" && activeWorkstream !== targetWs) ||
        (activePhase && activePhase !== targetPhase) ||
        searchQuery !== "";
      if (needsReset) {
        activeWorkstream = "all";
        activePhase = "";
        searchQuery = "";
        searchInput.value = "";
        setWorkstreamButtonStyles("all");
        applyFilters();
      }

      target.open = true;
    });
  });

  // Initialise filter state from URL query params
  (function initFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const wsParam = params.get("ws");
    const phaseParam = params.get("phase");
    const qParam = params.get("q");

    if (wsParam && validWorkstreams.has(wsParam)) {
      activeWorkstream = wsParam;
      setWorkstreamButtonStyles(wsParam);
    }
    if (phaseParam && validPhases.has(phaseParam) && activeWorkstream !== "all") {
      activePhase = phaseParam;
    }
    if (qParam) {
      searchQuery = qParam;
      searchInput.value = qParam;
    }

    if (wsParam || phaseParam || qParam) {
      applyFilters();
    }
  })();
</script>
