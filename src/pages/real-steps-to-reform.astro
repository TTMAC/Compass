---
import PageLayout from "@layouts/PageLayout.astro";
import {
  workstreams,
  reforms,
  legislativeItems,
  milestones,
  digitalInfrastructure,
  scorecardOutcomes,
} from "@data/reforms";

const reformCount = reforms.length;
const legislativeCount = legislativeItems.length;
const reformTitleById = new Map(reforms.map((r) => [r.id, r.title]));

// Group legislative items by type for the Legislative Programme section
const legislativeGroups: {
  type: "new" | "amendment" | "constitutional";
  heading: string;
  description: string;
  items: typeof legislativeItems;
}[] = [
  {
    type: "new",
    heading: "New Statutes",
    description: "Wholly new legislation required to create institutions or frameworks that do not currently exist.",
    items: legislativeItems.filter((l) => l.type === "new"),
  },
  {
    type: "amendment",
    heading: "Amendments to Existing Legislation",
    description: "Changes to existing Acts to enable or implement the reform programme.",
    items: legislativeItems.filter((l) => l.type === "amendment"),
  },
  {
    type: "constitutional",
    heading: "Possible Constitutional Amendment",
    description: "Changes to the Constitution — to be pursued only if legislative reform proves insufficient.",
    items: legislativeItems.filter((l) => l.type === "constitutional"),
  },
].filter((g) => g.items.length > 0);

// Group reforms by workstream then phase
const grouped = workstreams.map((ws) => {
  const wsReforms = reforms.filter((r) => r.workstream === ws.id);
  const phases = ws.phases.map((phase) => {
    const phaseReforms = wsReforms.filter((r) => r.phase === phase.id);
    // Group by subgroup within phase
    const subgroups: { name: string; reforms: typeof phaseReforms }[] = [];
    const seen = new Set<string>();
    for (const r of phaseReforms) {
      const key = r.subgroup ?? "__none__";
      if (!seen.has(key)) {
        seen.add(key);
        subgroups.push({
          name: r.subgroup ?? "",
          reforms: phaseReforms.filter(
            (pr) => (pr.subgroup ?? "") === (r.subgroup ?? ""),
          ),
        });
      }
    }
    return { ...phase, reforms: phaseReforms, subgroups };
  });
  return { ...ws, phases, reformCount: wsReforms.length };
});
---

<PageLayout
  title="Real Steps to Reform"
  description="An interactive explorer of South Africa's sequenced reform programme — 80+ concrete reforms across safety, governance, economy, and human development over 10 years."
>
  <!-- Hero -->
  <header class="mb-10">
    <h1 class="font-heading text-3xl md:text-4xl font-bold text-text-primary mb-3">
      Real Steps to Reform
    </h1>
    <p class="text-lg text-text-secondary leading-relaxed mb-4">
      South Africa doesn't lack diagnosis — it lacks a sequenced, concrete programme of institutional reform.
      This page consolidates <strong class="text-text-primary">{reformCount} specific reforms</strong> across
      four workstreams, phased over 10 years, with the <strong class="text-text-primary">{legislativeCount} legislative
      changes</strong> required to make them real.
    </p>
    <p class="text-text-secondary leading-relaxed">
      Filter by workstream, explore each phase, and see exactly what needs to happen — and in what order.
    </p>
  </header>

  <!-- On-page navigation -->
  <nav class="mb-8 flex flex-wrap gap-x-4 gap-y-1 text-xs font-heading" aria-label="Jump to section">
    <span class="text-text-secondary font-semibold">Jump to:</span>
    <a href="#timeline" class="text-compass-green hover:underline">Timeline</a>
    <a href="#milestones" class="text-compass-green hover:underline">Milestones</a>
    {grouped.map((ws) => (
      <a href={`#${ws.id}`} class="hover:underline" style={`color: ${ws.color}`}>{ws.shortTitle}</a>
    ))}
    <a href="#legislative" class="text-compass-green hover:underline">Legislative Programme</a>
    <a href="#enablers" class="text-compass-green hover:underline">Digital Infrastructure</a>
  </nav>

  <!-- Frameworks reference card -->
  <aside class="mb-8 p-4 rounded-lg border border-compass-green/30 bg-compass-green-light/40">
    <p class="font-heading text-sm font-bold text-text-primary mb-1">
      The diagnostic lens behind these reforms
    </p>
    <p class="text-sm text-text-secondary leading-relaxed">
      Every reform on this page is grounded in four diagnostic frameworks: the
      <strong class="text-text-primary">RAARICLE™</strong> eight-element test, the
      <strong class="text-text-primary">five failure patterns</strong>, the
      <strong class="text-text-primary">capture vulnerability assessment</strong>, and the
      <strong class="text-text-primary">structural principles</strong> for institutional design.
      <a href="/diagnostic-frameworks" class="text-compass-green font-semibold hover:underline">Read the full diagnostic toolkit →</a>
    </p>
  </aside>

  <!-- Workstream Filter -->
  <div
    class="sticky top-16 bg-bg-primary/95 backdrop-blur-sm py-2.5 z-30 border-b border-gray-100 mb-8"
  >
    <div class="flex flex-wrap items-center gap-2">
      <div
        class="flex flex-wrap items-center gap-1.5 flex-1"
        role="group"
        aria-label="Filter reforms by workstream"
      >
        <button
          type="button"
          class="reform-filter-btn px-3 py-1.5 rounded-full font-heading text-sm font-semibold transition-colors border-2 border-compass-green bg-compass-green text-white"
          data-filter="all"
          aria-pressed="true"
        >
          All <span class="opacity-70 font-normal">({reformCount})</span>
        </button>
        {grouped.map((ws) => (
          <button
            type="button"
            class="reform-filter-btn px-3 py-1.5 rounded-full font-heading text-sm font-semibold transition-colors border-2"
            style={`border-color: ${ws.color}; color: ${ws.color}; background-color: transparent`}
            data-filter={ws.id}
            data-color={ws.color}
            data-light={ws.lightColor}
            aria-pressed="false"
          >
            {ws.shortTitle} <span class="opacity-70 font-normal">({ws.reformCount})</span>
          </button>
        ))}
      </div>
      <div class="relative w-full sm:w-64 shrink-0">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-secondary pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <input
          type="search"
          id="reform-search"
          class="w-full pl-9 pr-3 py-1.5 rounded-lg border border-gray-200 bg-white font-heading text-sm text-text-primary placeholder:text-text-secondary/60 focus:outline-none focus:border-compass-green focus:ring-1 focus:ring-compass-green"
          placeholder="Search reforms…"
          aria-label="Search reforms by keyword"
        />
      </div>
      <span id="reform-count" class="font-heading text-xs text-text-secondary whitespace-nowrap shrink-0" aria-live="polite">
        {reformCount} reforms
      </span>
    </div>
  </div>

  <!-- Phase Timeline -->
  <section id="timeline" class="mb-10 scroll-mt-32" aria-label="10-year reform timeline">
    <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 mb-3">
      <h2 class="font-heading text-xl font-bold text-text-primary">
        10-Year Timeline
      </h2>
      <p class="font-heading text-xs text-text-secondary">
        Click a phase to filter reforms →
      </p>
    </div>
    {/* Mobile: stacked phase pills per workstream */}
    <div class="md:hidden space-y-3">
      {grouped.map((ws) => (
        <div class="reform-ws-row" data-workstream={ws.id}>
          <p class="font-heading text-xs font-bold mb-1.5" style={`color: ${ws.color}`}>
            {ws.shortTitle}
          </p>
          <div class="flex flex-wrap gap-1.5">
            {ws.phases.map((phase) => {
              const phaseOpacity = phase.id === "phase-1" ? 0.7 : phase.id === "phase-2" ? 0.85 : 1;
              return (
                <button
                  type="button"
                  class="reform-phase-btn text-left px-2.5 py-1 rounded text-[11px] font-heading font-semibold text-white cursor-pointer transition hover:brightness-110 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-1 focus-visible:ring-gray-500"
                  style={`background-color: ${ws.color}; opacity: ${phaseOpacity}`}
                  data-workstream={ws.id}
                  data-phase={phase.id}
                  aria-label={`Filter reforms to ${phase.label}, ${phase.years}, ${ws.shortTitle}`}
                >
                  {phase.label} · {phase.years}
                </button>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    {/* Desktop: horizontal bar chart */}
    <div class="hidden md:block overflow-x-auto -mx-4 px-4">
      <div class="min-w-[600px]">
        {grouped.map((ws) => (
          <div
            class="reform-ws-row mb-3 flex items-center gap-3"
            data-workstream={ws.id}
          >
            <span
              class="font-heading text-xs font-bold w-16 shrink-0 text-right"
              style={`color: ${ws.color}`}
            >
              {ws.shortTitle}
            </span>
            <div class="flex-1 flex h-8 rounded overflow-hidden gap-px">
              {ws.phases.map((phase) => {
                const startYear = parseInt(phase.years.match(/\d+/)?.[0] ?? "1");
                const endYear = parseInt(phase.years.match(/\d+$/)?.[0] ?? "10");
                const widthPct = ((endYear - startYear + 1) / 10) * 100;
                const leftPct = ((startYear - 1) / 10) * 100;
                const phaseOpacity = phase.id === "phase-1" ? 0.7 : phase.id === "phase-2" ? 0.85 : 1;
                return (
                  <button
                    type="button"
                    class="reform-phase-btn relative flex items-center justify-center text-white font-heading text-[11px] font-semibold px-2 cursor-pointer transition hover:brightness-110 hover:ring-2 hover:ring-offset-1 hover:ring-gray-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-1 focus-visible:ring-gray-500 whitespace-nowrap overflow-hidden"
                    style={`width: ${widthPct}%; background-color: ${ws.color}; opacity: ${phaseOpacity}; margin-left: ${phase.id === "phase-1" ? leftPct + "%" : "0"}`}
                    data-workstream={ws.id}
                    data-phase={phase.id}
                    title={`Click to filter to ${phase.label} (${phase.years})`}
                    aria-label={`Filter reforms to ${phase.label}, ${phase.years}, ${ws.shortTitle}`}
                  >
                    <span class="truncate">{phase.label}</span>
                  </button>
                );
              })}
            </div>
          </div>
        ))}
        <!-- Year markers -->
        <div class="flex items-center gap-3 mt-1">
          <span class="w-16 shrink-0"></span>
          <div class="flex-1 flex justify-between text-[10px] text-text-secondary font-heading">
            {Array.from({ length: 10 }, (_, i) => (
              <span>Yr {i + 1}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Milestones -->
  <section id="milestones" class="mb-10 scroll-mt-32" aria-label="Reform milestones">
    <h2 class="font-heading text-xl font-bold text-text-primary mb-4">
      Milestones
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {milestones.map((m) => {
        const colors = m.period === "Year 1"
          ? { bg: "#E6EFE8", border: "#355E3B", text: "#355E3B" }
          : m.period === "Year 5"
            ? { bg: "#F3EBDA", border: "#7A5C1F", text: "#7A5C1F" }
            : { bg: "#E8E0F4", border: "#553691", text: "#553691" };
        return (
          <div class="rounded-lg border p-5" style={`border-color: ${colors.border}30; background-color: ${colors.bg}40`}>
            <p class="font-heading text-lg font-bold mb-1" style={`color: ${colors.text}`}>
              {m.period}
            </p>
            <p class="font-heading text-xs font-semibold text-text-secondary uppercase tracking-wide mb-3">
              {m.label}
            </p>
            <ul class="space-y-2">
              {m.items.map((item) => (
                <li
                  class="milestone-item flex items-start gap-2 text-sm text-text-secondary leading-relaxed"
                  data-workstream={item.workstream}
                >
                  <span class="shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full" style={`background-color: ${colors.text}`}></span>
                  {item.text}
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Active phase filter indicator -->
  <div
    id="active-filter-indicator"
    class="hidden mb-6 p-3 rounded-lg border border-gray-200 bg-bg-secondary flex items-center justify-between"
    aria-live="polite"
  >
    <span id="active-filter-text" class="font-heading text-sm text-text-secondary"></span>
    <button
      type="button"
      id="clear-phase-filter"
      class="font-heading text-xs text-compass-green hover:underline"
    >
      Clear filter
    </button>
  </div>

  <!-- Empty state (shown when filters/search match nothing) -->
  <div
    id="reform-empty-state"
    class="hidden mb-10 p-8 rounded-lg border border-dashed border-gray-300 bg-bg-secondary text-center"
    aria-live="polite"
  >
    <p class="font-heading text-base font-bold text-text-primary mb-1">
      No reforms match your filters
    </p>
    <p class="text-sm text-text-secondary mb-4" id="reform-empty-detail">
      Try a different workstream, phase, or search term.
    </p>
    <button
      type="button"
      id="reform-clear-all"
      class="font-heading text-sm font-semibold px-4 py-2 rounded-full border-2 border-compass-green text-compass-green hover:bg-compass-green hover:text-white transition-colors"
    >
      Clear all filters
    </button>
  </div>

  <!-- Reform Cards by Workstream -->
  {grouped.map((ws) => (
    <section
      id={ws.id}
      class="reform-ws-section mb-12 scroll-mt-32"
      data-workstream={ws.id}
      aria-label={`${ws.title} reforms`}
    >
      <!-- Workstream header -->
      <div class="flex items-center gap-3 mb-2">
        <span
          class="inline-block w-4 h-4 rounded-full shrink-0"
          style={`background-color: ${ws.color}`}
        ></span>
        <h2 class="font-heading text-2xl font-bold text-text-primary">
          {ws.title}
        </h2>
      </div>
      <p class="text-text-secondary leading-relaxed mb-3 ml-7">
        {ws.vision}
      </p>
      {ws.id === "safety-security" && (
        <aside class="ml-7 mb-4 p-4 rounded-lg border-l-4" style={`border-color: ${ws.color}; background-color: ${ws.lightColor}60`}>
          <p class="font-heading text-sm font-bold text-text-primary mb-1">
            Why this workstream is sequenced first
          </p>
          <p class="text-sm text-text-secondary leading-relaxed">
            Without a functioning criminal justice system, every other reform is built on sand. Investors won't invest in unsafe cities. Children can't learn in violent schools. Municipalities can't collect revenue when infrastructure is vandalised with impunity. The reforms below create the preconditions — rule of law, institutional credibility, and physical security — that the economic, governance, and human development workstreams depend on to succeed.
          </p>
        </aside>
      )}
      <div class="ml-7 mb-6 flex gap-2" role="group" aria-label={`Expand or collapse ${ws.title} reform cards`}>
        <button
          type="button"
          class="reform-expand-all font-heading text-xs font-semibold px-3 py-1 rounded border border-gray-200 text-text-secondary hover:border-gray-300 hover:bg-bg-secondary transition-colors"
          data-workstream={ws.id}
          data-action="expand"
        >
          Expand all
        </button>
        <button
          type="button"
          class="reform-expand-all font-heading text-xs font-semibold px-3 py-1 rounded border border-gray-200 text-text-secondary hover:border-gray-300 hover:bg-bg-secondary transition-colors"
          data-workstream={ws.id}
          data-action="collapse"
        >
          Collapse all
        </button>
      </div>

      {/* Phases */}
      {ws.phases.map((phase) => (
        <div
          class="reform-phase-section mb-8"
          data-workstream={ws.id}
          data-phase={phase.id}
        >
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
            <h3 class="font-heading text-lg font-bold text-text-primary">
              {phase.label}
            </h3>
            <span class="font-heading text-xs font-semibold px-2 py-0.5 rounded-full text-white" style={`background-color: ${ws.color}`}>
              {phase.years}
            </span>
          </div>
          <p class="text-sm text-text-secondary mb-4 italic">
            Priority: {phase.priority}
          </p>

          {/* Subgroups or flat list */}
          {phase.subgroups.map((sg) => (
            <div class="mb-4">
              {sg.name && (
                <h4 class="font-heading text-sm font-bold text-text-secondary uppercase tracking-wide mb-2 ml-1">
                  {sg.name}
                </h4>
              )}
              <div class="space-y-2">
                {sg.reforms.map((reform) => (
                  <details
                    id={`reform-${reform.id}`}
                    class="reform-card group border border-gray-200 rounded-lg overflow-hidden transition-colors hover:border-gray-300 scroll-mt-32 target:border-compass-green target:shadow-sm"
                    data-workstream={reform.workstream}
                    data-phase={reform.phase}
                  >
                    <summary
                      class="flex items-center gap-3 px-4 py-3 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none"
                    >
                      <span
                        class="font-heading text-xs font-bold shrink-0 w-10 text-center py-0.5 rounded"
                        style={`background-color: ${ws.lightColor}; color: ${ws.color}`}
                      >
                        {reform.id}
                      </span>
                      <span class="font-heading text-sm font-semibold text-text-primary flex-1">
                        {reform.title}
                      </span>
                      {reform.scope && reform.scope.length > 0 && (
                        <span class="hidden sm:flex items-center gap-1 shrink-0">
                          {reform.scope.map((s) => {
                            const label = s === "national" ? "Nat" : s === "provincial" ? "Prov" : "Mun";
                            return (
                              <span
                                class="px-1.5 py-0.5 rounded text-[10px] font-heading font-semibold uppercase bg-gray-100 text-text-secondary"
                                title={s.charAt(0).toUpperCase() + s.slice(1)}
                              >
                                {label}
                              </span>
                            );
                          })}
                        </span>
                      )}
                      {reform.articleSlug && (
                        <span
                          class="hidden sm:inline-flex items-center gap-1 shrink-0 px-1.5 py-0.5 rounded text-[10px] font-heading font-semibold uppercase bg-compass-green-light text-compass-green"
                          title="Full article available"
                          aria-label="Full article available"
                        >
                          <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                          </svg>
                          Article
                        </span>
                      )}
                      <svg
                        class="w-4 h-4 text-text-secondary shrink-0 transition-transform group-open:rotate-180"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                        aria-hidden="true"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                      </svg>
                    </summary>
                    <div class="px-4 pb-4 pt-1 border-t border-gray-100">
                      <p class="text-sm text-text-secondary leading-relaxed mb-3">
                        {reform.description}
                      </p>
                      <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs">
                        {reform.legislative && (
                          <div>
                            <span class="font-heading font-semibold text-text-primary">Legislative: </span>
                            <span class="text-text-secondary">{reform.legislative}</span>
                          </div>
                        )}
                        {reform.scope && (
                          <div class="flex items-center gap-1">
                            <span class="font-heading font-semibold text-text-primary">Scope: </span>
                            {reform.scope.map((s) => (
                              <span class="px-1.5 py-0.5 rounded text-[10px] font-heading font-semibold uppercase bg-gray-100 text-text-secondary">
                                {s}
                              </span>
                            ))}
                          </div>
                        )}
                        {reform.dependsOn && reform.dependsOn.length > 0 && (
                          <div class="flex items-center gap-1 flex-wrap">
                            <span class="font-heading font-semibold text-text-primary">Depends on: </span>
                            {reform.dependsOn.map((depId) => {
                              const depTitle = reformTitleById.get(depId);
                              return (
                                <a
                                  href={`#reform-${depId}`}
                                  class="reform-dep-link px-1.5 py-0.5 rounded text-[10px] font-heading font-semibold bg-gray-100 text-text-secondary hover:bg-compass-green-light hover:text-compass-green transition-colors"
                                  data-dep-id={depId}
                                  title={depTitle ? `${depId} — ${depTitle}` : depId}
                                >
                                  {depId}
                                </a>
                              );
                            })}
                          </div>
                        )}
                      </div>
                      {reform.articleSlug && (
                        <a
                          href={`/articles/${reform.articleSlug}`}
                          class="inline-flex items-center gap-1 mt-3 text-xs font-heading font-semibold text-compass-green hover:text-compass-green-dark hover:underline transition-colors"
                        >
                          Read the full analysis
                          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                          </svg>
                        </a>
                      )}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          ))}
        </div>
      ))}

      {/* Scorecard */}
      {scorecardOutcomes[ws.id] && (
        <div class="mt-8">
          <h3 class="font-heading text-lg font-bold text-text-primary mb-2">
            Example Scorecard for Outcome Areas
          </h3>
          <p class="text-sm text-text-secondary mb-4">
            {scorecardOutcomes[ws.id].length} outcomes to track quarterly. Baselines
            and targets will be populated as the scorecard is operationalised — empty
            cells are shown as &ldquo;&mdash;&rdquo;.
          </p>
          <div class="overflow-x-auto -mx-4 px-4">
            <table class="min-w-full text-sm border-collapse">
              <thead>
                <tr class="border-b-2" style={`border-color: ${ws.color}`}>
                  <th class="text-left font-heading font-bold text-text-primary py-2 pr-3 w-8" scope="col">#</th>
                  <th class="text-left font-heading font-bold text-text-primary py-2 pr-3" scope="col">Outcome</th>
                  <th class="text-left font-heading font-bold text-text-primary py-2 px-3 whitespace-nowrap" scope="col">Baseline</th>
                  <th class="text-left font-heading font-bold text-text-primary py-2 px-3 whitespace-nowrap" scope="col">Year 5 Target</th>
                  <th class="text-left font-heading font-bold text-text-primary py-2 pl-3 whitespace-nowrap" scope="col">Year 10 Target</th>
                </tr>
              </thead>
              <tbody>
                {scorecardOutcomes[ws.id].map((row, i) => (
                  <tr class="border-b border-gray-100 align-top">
                    <td class="font-heading text-xs font-bold py-2 pr-3" style={`color: ${ws.color}`}>
                      {i + 1}
                    </td>
                    <td class="py-2 pr-3 text-text-secondary">{row.outcome}</td>
                    <td class="py-2 px-3 text-text-secondary whitespace-nowrap">{row.baseline ?? "—"}</td>
                    <td class="py-2 px-3 text-text-secondary whitespace-nowrap">{row.year5 ?? "—"}</td>
                    <td class="py-2 pl-3 text-text-secondary whitespace-nowrap">{row.year10 ?? "—"}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </section>
  ))}

  <!-- Legislative Programme -->
  <section id="legislative" class="mb-12 scroll-mt-32" aria-label="Legislative programme">
    <h2 class="font-heading text-2xl font-bold text-text-primary mb-4">
      Legislative Programme
    </h2>
    <p class="text-text-secondary mb-6">
      {legislativeCount} legislative changes required: {legislativeItems.filter(l => l.type === "new").length} new
      statutes, {legislativeItems.filter(l => l.type === "amendment").length} amendments to existing
      legislation, and {legislativeItems.filter(l => l.type === "constitutional").length} possible constitutional amendment.
    </p>

    {legislativeGroups.map((group) => (
      <div class="mb-8 last:mb-0">
        <h3 class="font-heading text-lg font-bold text-text-primary mb-1 flex items-baseline gap-2">
          {group.heading}
          <span class="font-heading text-xs font-semibold text-text-secondary">({group.items.length})</span>
        </h3>
        <p class="text-sm text-text-secondary mb-3">{group.description}</p>
        <div class="overflow-x-auto -mx-4 px-4 border border-gray-200 rounded-lg">
          <table class="min-w-full text-sm border-collapse">
            <thead class="bg-bg-secondary">
              <tr class="border-b border-gray-200">
                <th class="text-left font-heading text-xs font-bold text-text-secondary uppercase tracking-wide py-2 px-3 w-12" scope="col">ID</th>
                <th class="text-left font-heading text-xs font-bold text-text-secondary uppercase tracking-wide py-2 px-3" scope="col">Legislation</th>
                <th class="text-left font-heading text-xs font-bold text-text-secondary uppercase tracking-wide py-2 px-3 whitespace-nowrap" scope="col">Workstream</th>
                <th class="text-left font-heading text-xs font-bold text-text-secondary uppercase tracking-wide py-2 px-3 whitespace-nowrap" scope="col">Phase</th>
              </tr>
            </thead>
            <tbody>
              {group.items.map((item) => {
                const ws = workstreams.find((w) => w.id === item.workstream)!;
                const phaseYears = ws.phases.find((p) => p.id === item.phase)?.years;
                return (
                  <tr class="border-b border-gray-100 last:border-0 hover:bg-bg-secondary transition-colors group">
                    <td class="font-heading text-xs font-bold text-text-secondary py-3 px-3 whitespace-nowrap align-middle">{item.id}</td>
                    <td class="py-3 px-3 align-middle">
                      <a
                        href={`/articles/${item.articleSlug}`}
                        class="font-heading text-sm font-semibold text-text-primary group-hover:text-compass-green transition-colors"
                      >
                        {item.name}
                      </a>
                    </td>
                    <td class="py-3 px-3 whitespace-nowrap align-middle">
                      <span
                        class="font-heading text-[10px] font-bold uppercase px-2 py-0.5 rounded-full text-white"
                        style={`background-color: ${ws.color}`}
                      >
                        {ws.shortTitle}
                      </span>
                    </td>
                    <td class="font-heading text-xs text-text-secondary py-3 px-3 whitespace-nowrap align-middle">
                      {phaseYears}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    ))}
  </section>

  <!-- Digital Infrastructure -->
  <section id="enablers" class="mb-12 scroll-mt-32" aria-label="Digital infrastructure enablers">
    <h2 class="font-heading text-2xl font-bold text-text-primary mb-2">
      Digital Infrastructure Enablers
    </h2>
    <p class="text-text-secondary mb-6 leading-relaxed">
      Cross-cutting digital systems that the reform programme builds or extends. Each platform serves multiple
      workstreams and is treated as core infrastructure rather than as a tool for any single function.
    </p>
    <div class="space-y-2">
      {digitalInfrastructure.map((di) => (
        <div class="flex flex-wrap items-center gap-3 px-4 py-3 border border-gray-200 rounded-lg">
          <span class="font-heading text-xs font-bold text-compass-green w-10">{di.id}</span>
          <span class="font-heading text-sm font-semibold text-text-primary flex-1 min-w-[200px]">
            {di.initiative}
          </span>
          <span class="text-xs text-text-secondary">{di.workstreams}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Cross-references -->
  <section class="mb-12" aria-label="Companion pages">
    <h2 class="font-heading text-xl font-bold text-text-primary mb-4">
      Companion pages
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a
        href="/diagnostic-frameworks"
        class="border border-gray-200 rounded-lg p-5 hover:border-compass-green hover:shadow-md transition-all group"
      >
        <p class="font-heading text-base font-bold text-text-primary group-hover:text-compass-green transition-colors mb-2">
          Diagnostic Frameworks
        </p>
        <p class="text-sm text-text-secondary leading-relaxed">
          The RAARICLE™ framework, the five failure patterns, the capture vulnerability assessment, and the structural principles that justify each reform on this page.
        </p>
      </a>
      <a
        href="/reform-scorecard"
        class="border border-gray-200 rounded-lg p-5 hover:border-compass-green hover:shadow-md transition-all group"
      >
        <p class="font-heading text-base font-bold text-text-primary group-hover:text-compass-green transition-colors mb-2">
          Reinforcing Cycle Scorecard
        </p>
        <p class="text-sm text-text-secondary leading-relaxed">
          The 15 indicators across safety, growth, and development that show whether the reforms on this page are producing systemic change.
        </p>
      </a>
    </div>
  </section>

  <!-- Source note -->
  <footer class="border-t border-gray-200 pt-6 mt-12">
    <p class="text-xs text-text-secondary leading-relaxed">
      This reform programme is derived from the GovCompass article series. Each recommendation is grounded in
      comparative institutional analysis, South African constitutional law, and evidence from international
      reform experiences. For detailed analysis supporting each recommendation, explore the individual articles
      in the <a href="/big-picture" class="text-compass-green hover:underline">GovCompass series</a>.
    </p>
  </footer>
</PageLayout>

<script>
  // ── Workstream filtering ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".reform-filter-btn");
  const wsSections = document.querySelectorAll<HTMLElement>(".reform-ws-section");
  const wsTimelineRows = document.querySelectorAll<HTMLElement>(".reform-ws-row");
  const phaseSections = document.querySelectorAll<HTMLElement>(".reform-phase-section");
  const reformCards = document.querySelectorAll<HTMLElement>(".reform-card");
  const indicator = document.getElementById("active-filter-indicator")!;
  const indicatorText = document.getElementById("active-filter-text")!;
  const clearBtn = document.getElementById("clear-phase-filter")!;
  const searchInput = document.getElementById("reform-search") as HTMLInputElement;
  const reformCountEl = document.getElementById("reform-count")!;
  const emptyState = document.getElementById("reform-empty-state")!;
  const emptyDetail = document.getElementById("reform-empty-detail")!;
  const clearAllBtn = document.getElementById("reform-clear-all")!;
  const totalReforms = reformCards.length;

  let activeWorkstream = "all";
  let activePhase = "";
  let searchQuery = "";

  const validWorkstreams = new Set<string>(
    Array.from(filterBtns).map((b) => b.dataset.filter!),
  );
  const validPhases = new Set<string>(
    Array.from(document.querySelectorAll<HTMLButtonElement>(".reform-phase-btn"))
      .map((b) => b.dataset.phase!),
  );

  function setWorkstreamButtonStyles(filter: string) {
    filterBtns.forEach((b) => {
      const isActive = b.dataset.filter === filter;
      b.setAttribute("aria-pressed", String(isActive));
      if (isActive) {
        if (filter === "all") {
          b.style.cssText = "border-color: #355E3B; background-color: #355E3B; color: white";
        } else {
          b.style.cssText = `border-color: ${b.dataset.color}; background-color: ${b.dataset.color}; color: white`;
        }
      } else {
        if (b.dataset.filter === "all") {
          b.style.cssText = "border-color: #355E3B; background-color: transparent; color: #355E3B";
        } else {
          b.style.cssText = `border-color: ${b.dataset.color}; background-color: transparent; color: ${b.dataset.color}`;
        }
      }
    });
  }

  function syncUrl() {
    const params = new URLSearchParams();
    if (activeWorkstream !== "all") params.set("ws", activeWorkstream);
    if (activePhase) params.set("phase", activePhase);
    if (searchQuery) params.set("q", searchQuery);
    const qs = params.toString();
    const newUrl = `${window.location.pathname}${qs ? "?" + qs : ""}${window.location.hash}`;
    window.history.replaceState(null, "", newUrl);
  }

  function applyFilters() {
    const query = searchQuery.toLowerCase();
    let visibleCount = 0;

    // Filter individual reform cards
    reformCards.forEach((card) => {
      const ws = card.dataset.workstream!;
      const ph = card.dataset.phase!;
      const wsMatch = activeWorkstream === "all" || activeWorkstream === ws;
      const phMatch = !activePhase || activePhase === ph;
      const textMatch = !query || card.textContent!.toLowerCase().includes(query);
      const visible = wsMatch && phMatch && textMatch;
      card.style.display = visible ? "" : "none";
      if (visible) visibleCount++;
    });

    // Hide empty phase sections (all cards hidden)
    phaseSections.forEach((s) => {
      const hasVisible = s.querySelector('.reform-card:not([style*="display: none"])');
      const ws = s.dataset.workstream!;
      const wsMatch = activeWorkstream === "all" || activeWorkstream === ws;
      s.style.display = wsMatch && hasVisible ? "" : "none";
    });

    // Hide empty workstream sections
    wsSections.forEach((s) => {
      const ws = s.dataset.workstream!;
      const wsMatch = activeWorkstream === "all" || activeWorkstream === ws;
      const hasVisible = s.querySelector('.reform-card:not([style*="display: none"])');
      s.style.display = wsMatch && hasVisible ? "" : "none";
    });

    // Timeline rows follow workstream filter only (not search)
    wsTimelineRows.forEach((r) => {
      const ws = r.dataset.workstream!;
      r.style.display = activeWorkstream === "all" || activeWorkstream === ws ? "" : "none";
    });

    // Milestone items follow workstream filter only
    document.querySelectorAll<HTMLElement>(".milestone-item").forEach((item) => {
      const ws = item.dataset.workstream!;
      item.style.display = activeWorkstream === "all" || activeWorkstream === ws ? "" : "none";
    });

    // Reform count
    if (query || activeWorkstream !== "all" || activePhase) {
      reformCountEl.textContent = `${visibleCount} of ${totalReforms} reforms`;
    } else {
      reformCountEl.textContent = `${totalReforms} reforms`;
    }

    // Empty state
    const hasAnyFilter = !!(query || activeWorkstream !== "all" || activePhase);
    if (visibleCount === 0 && hasAnyFilter) {
      emptyState.classList.remove("hidden");
      const parts: string[] = [];
      if (query) parts.push(`search "${query}"`);
      if (activeWorkstream !== "all") {
        const wsBtn = document.querySelector<HTMLButtonElement>(
          `.reform-filter-btn[data-filter="${activeWorkstream}"]`,
        );
        if (wsBtn) parts.push(`workstream ${wsBtn.textContent?.trim()}`);
      }
      if (activePhase) parts.push(activePhase.replace("-", " "));
      emptyDetail.textContent = parts.length
        ? `No reforms match ${parts.join(" + ")}. Try a different filter or clear them all.`
        : "Try a different workstream, phase, or search term.";
    } else {
      emptyState.classList.add("hidden");
    }

    // Phase filter indicator
    if (activePhase) {
      indicator.classList.remove("hidden");
      indicator.classList.add("flex");
      const phaseBtn = document.querySelector<HTMLButtonElement>(
        `.reform-phase-btn[data-phase="${activePhase}"][data-workstream="${activeWorkstream}"]`
      );
      indicatorText.textContent = phaseBtn
        ? `Showing: ${phaseBtn.title}`
        : `Filtered to ${activePhase.replace("-", " ")}`;
    } else {
      indicator.classList.add("hidden");
      indicator.classList.remove("flex");
    }

    syncUrl();
  }

  // Search input
  let searchTimeout: ReturnType<typeof setTimeout>;
  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      searchQuery = searchInput.value.trim();
      applyFilters();
    }, 150);
  });

  // Workstream filter buttons
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;
      activeWorkstream = filter;
      activePhase = ""; // Reset phase filter when switching workstream

      setWorkstreamButtonStyles(filter);

      applyFilters();
    });
  });

  // Phase timeline buttons
  document.querySelectorAll<HTMLButtonElement>(".reform-phase-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const ws = btn.dataset.workstream!;
      const phase = btn.dataset.phase!;

      // If clicking the same phase, toggle it off
      if (activeWorkstream === ws && activePhase === phase) {
        activePhase = "";
      } else {
        // Set workstream filter to match
        if (activeWorkstream !== ws) {
          activeWorkstream = ws;
          setWorkstreamButtonStyles(ws);
        }
        activePhase = phase;
      }

      applyFilters();
    });
  });

  // Clear phase filter
  clearBtn.addEventListener("click", () => {
    activePhase = "";
    applyFilters();
  });

  // Clear all filters (from empty state)
  clearAllBtn.addEventListener("click", () => {
    activeWorkstream = "all";
    activePhase = "";
    searchQuery = "";
    searchInput.value = "";
    setWorkstreamButtonStyles("all");
    applyFilters();
  });

  // Expand all / Collapse all buttons per workstream section
  document.querySelectorAll<HTMLButtonElement>(".reform-expand-all").forEach((btn) => {
    btn.addEventListener("click", () => {
      const ws = btn.dataset.workstream!;
      const action = btn.dataset.action!;
      const shouldOpen = action === "expand";
      document
        .querySelectorAll<HTMLDetailsElement>(`.reform-card[data-workstream="${ws}"]`)
        .forEach((card) => {
          card.open = shouldOpen;
        });
    });
  });

  // Dependency links: open the target reform card so it's visible after anchor scroll
  document.querySelectorAll<HTMLAnchorElement>(".reform-dep-link").forEach((link) => {
    link.addEventListener("click", (e) => {
      const depId = link.dataset.depId!;
      const target = document.getElementById(`reform-${depId}`) as HTMLDetailsElement | null;
      if (!target) return;

      // If active filters would hide the target, reset workstream/phase/search
      // so the user actually sees the card they're jumping to.
      const targetWs = target.dataset.workstream!;
      const targetPhase = target.dataset.phase!;
      const needsReset =
        (activeWorkstream !== "all" && activeWorkstream !== targetWs) ||
        (activePhase && activePhase !== targetPhase) ||
        searchQuery !== "";
      if (needsReset) {
        activeWorkstream = "all";
        activePhase = "";
        searchQuery = "";
        searchInput.value = "";
        setWorkstreamButtonStyles("all");
        applyFilters();
      }

      target.open = true;
    });
  });

  // Initialise filter state from URL query params
  (function initFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const wsParam = params.get("ws");
    const phaseParam = params.get("phase");
    const qParam = params.get("q");

    if (wsParam && validWorkstreams.has(wsParam)) {
      activeWorkstream = wsParam;
      setWorkstreamButtonStyles(wsParam);
    }
    if (phaseParam && validPhases.has(phaseParam) && activeWorkstream !== "all") {
      activePhase = phaseParam;
    }
    if (qParam) {
      searchQuery = qParam;
      searchInput.value = qParam;
    }

    if (wsParam || phaseParam || qParam) {
      applyFilters();
    }
  })();
</script>
