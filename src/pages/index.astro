---
import BaseLayout from "@layouts/BaseLayout.astro";
import EmailCapture from "@components/EmailCapture.astro";
import FeedbackLoop from "@components/FeedbackLoop.astro";
import { getCollection } from "astro:content";
import { pillars } from "@content/pillars";

const allArticles = await getCollection("articles");
const firstArticle = allArticles.find((a) => a.data.articleNumber === "1.1");

const pillarData = pillars.map((p) => {
  const count = allArticles.filter(
    (a) => (a.data.pillar ?? "government-structure") === p.slug,
  ).length;
  return { ...p, articleCount: count };
});
---

<BaseLayout
  title="GovCompass — Making SA's governance system legible"
  description="Making South Africa's governance system legible to ordinary citizens"
>
  <!-- Hero -->
  <section class="bg-compass-green text-white py-16 md:py-24">
    <div class="max-w-content mx-auto px-4 md:px-0 text-center">
      <h1 class="font-heading text-3xl md:text-5xl font-bold mb-6 leading-tight">
        Making South Africa's governance system legible to ordinary citizens
      </h1>
      <p class="text-lg md:text-xl opacity-90 max-w-lg mx-auto mb-8">
        Deep, analytical, fact-based, long-form political economy education covering government structure,
        citizen safety and security, the economy, and human development.
      </p>
      {
        firstArticle && (
          <a
            href={`/articles/${firstArticle.id.replace(/\.md$/, "")}`}
            class="inline-block px-6 py-3 bg-white text-compass-green font-heading font-semibold rounded hover:bg-gray-100 transition-colors"
          >
            Start reading
          </a>
        )
      }
    </div>
  </section>

  <!-- Problem statement -->
  <section class="py-12 md:py-16 bg-bg-secondary">
    <div class="max-w-content mx-auto px-4 md:px-0">
      <h2 class="font-heading text-2xl font-bold text-text-primary mb-4">
        The problem
      </h2>
      <p class="text-lg text-text-secondary leading-relaxed mb-4">
        South Africa has a sophisticated constitutional democracy — but most
        citizens have never been taught how it actually works. Without this
        knowledge, frustrations get directed at the wrong people, accountability
        mechanisms go unused, and public participation remains performative.
      </p>
      <p class="text-lg text-text-secondary leading-relaxed">
        GovCompass breaks this down across four interconnected topics — from how
        government is structured, to safety, the economy, and ultimately
        human development. Each topic builds on the others.
      </p>
    </div>
  </section>

  <!-- Pillar grid -->
  <section class="py-12 md:py-16">
    <div class="max-w-content mx-auto px-4 md:px-0">
      <h2 class="font-heading text-2xl font-bold text-text-primary mb-8">
        Four Topics, One Picture
      </h2>

      <!-- Feedback loop with pillar cards positioned around it -->
      <!-- Mobile: stacked layout -->
      <div class="block lg:hidden mb-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          {pillarData.filter((p) => p.slug !== "reform-agenda").map((p) => (
            <a
              href={`/pillars/${p.slug}`}
              class={`border rounded-lg p-5 hover:border-gray-300 transition-colors group ${
                p.slug === "government-structure"
                  ? "bg-compass-green-light border-compass-green/30 border-l-4 border-l-compass-green"
                  : "border-gray-200"
              }`}
            >
              <div class="flex items-center gap-2 mb-2">
                <span
                  class="inline-block w-3 h-3 rounded-full shrink-0"
                  style={`background-color: ${p.color}`}
                ></span>
                <span class="font-heading text-base font-bold text-text-primary group-hover:text-compass-green transition-colors">
                  {p.title}
                </span>
              </div>
              <p class="text-sm text-text-secondary mb-3">
                {p.description}
              </p>
              <span class={`font-heading text-text-secondary ${p.slug === "government-structure" ? "text-sm font-semibold" : "text-xs"}`}>
                {p.articleCount > 0
                  ? `${p.articleCount} article${p.articleCount === 1 ? "" : "s"}`
                  : "Coming soon"}
                {p.slug === "government-structure" && " — Start here"}
              </span>
            </a>
          ))}
        </div>
        <p class="text-sm text-text-secondary mb-3">These four topics form a reinforcing loop — progress in one drives progress in the others.</p>
        <a href="/big-picture" class="block bg-white border border-gray-200 rounded-xl p-4 shadow-sm hover:shadow-md hover:border-gray-300 transition-all">
          <FeedbackLoop />
          <p class="text-center text-xs text-text-secondary mt-3 font-heading">See how they connect &rarr;</p>
        </a>
      </div>

      <!-- Desktop: cards around the diagram -->
      <div class="hidden lg:block mb-8">
        {/* Row 1: Government Structure + Citizen Safety & Security */}
        <div class="grid grid-cols-2 gap-4 mb-4">
          {pillarData.filter((p) => p.slug === "government-structure").map((p) => (
            <a
              href={`/pillars/${p.slug}`}
              class="bg-compass-green-light border border-compass-green/30 border-l-4 border-l-compass-green rounded-lg p-5 hover:border-gray-300 hover:shadow-sm transition-all group"
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-block w-3 h-3 rounded-full shrink-0" style={`background-color: ${p.color}`}></span>
                <span class="font-heading text-base font-bold text-text-primary group-hover:text-compass-green transition-colors">
                  {p.title}
                </span>
              </div>
              <p class="text-sm text-text-secondary mb-3">{p.description}</p>
              <span class="text-sm font-heading font-semibold text-text-secondary">
                {p.articleCount > 0 ? `${p.articleCount} article${p.articleCount === 1 ? "" : "s"}` : "Coming soon"} — Start here
              </span>
            </a>
          ))}
          {pillarData.filter((p) => p.slug === "safety-security").map((p) => (
            <a
              href={`/pillars/${p.slug}`}
              class="border border-gray-200 rounded-lg p-5 hover:border-gray-300 hover:shadow-sm transition-all group"
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-block w-3 h-3 rounded-full shrink-0" style={`background-color: ${p.color}`}></span>
                <span class="font-heading text-base font-bold text-text-primary group-hover:text-compass-green transition-colors">
                  {p.title}
                </span>
              </div>
              <p class="text-sm text-text-secondary mb-3">{p.description}</p>
              <span class="text-xs font-heading text-text-secondary">
                {p.articleCount > 0 ? `${p.articleCount} article${p.articleCount === 1 ? "" : "s"}` : "Coming soon"}
              </span>
            </a>
          ))}
        </div>

        {/* Center: Feedback loop diagram */}
        <a href="/big-picture" class="block bg-white border border-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md hover:border-gray-300 transition-all mb-4">
          <FeedbackLoop />
          <p class="text-center text-xs text-text-secondary mt-3 font-heading">See how they connect &rarr;</p>
        </a>

        {/* Row 3: Economic Growth + Human Development */}
        <div class="grid grid-cols-2 gap-4">
          {pillarData.filter((p) => p.slug === "economic-growth").map((p) => (
            <a
              href={`/pillars/${p.slug}`}
              class="border border-gray-200 rounded-lg p-5 hover:border-gray-300 hover:shadow-sm transition-all group"
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-block w-3 h-3 rounded-full shrink-0" style={`background-color: ${p.color}`}></span>
                <span class="font-heading text-base font-bold text-text-primary group-hover:text-compass-green transition-colors">
                  {p.title}
                </span>
              </div>
              <p class="text-sm text-text-secondary mb-3">{p.description}</p>
              <span class="text-xs font-heading text-text-secondary">
                {p.articleCount > 0 ? `${p.articleCount} article${p.articleCount === 1 ? "" : "s"}` : "Coming soon"}
              </span>
            </a>
          ))}
          {pillarData.filter((p) => p.slug === "human-development").map((p) => (
            <a
              href={`/pillars/${p.slug}`}
              class="border border-gray-200 rounded-lg p-5 hover:border-gray-300 hover:shadow-sm transition-all group"
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-block w-3 h-3 rounded-full shrink-0" style={`background-color: ${p.color}`}></span>
                <span class="font-heading text-base font-bold text-text-primary group-hover:text-compass-green transition-colors">
                  {p.title}
                </span>
              </div>
              <p class="text-sm text-text-secondary mb-3">{p.description}</p>
              <span class="text-xs font-heading text-text-secondary">
                {p.articleCount > 0 ? `${p.articleCount} article${p.articleCount === 1 ? "" : "s"}` : "Coming soon"}
              </span>
            </a>
          ))}
        </div>
      </div>

      {pillarData.filter((p) => p.slug === "reform-agenda").map((p) => (
        <div class="mb-8 relative">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-px h-6 bg-gray-300"></div>
            <span class="text-xs font-heading text-text-secondary uppercase tracking-wide">Applies across all four topics</span>
          </div>
          <a
            href={`/pillars/${p.slug}`}
            class="block border border-gray-200 rounded-lg p-5 hover:border-gray-300 hover:shadow-sm transition-all group"
          >
            <div class="flex items-center gap-2 mb-2">
              <span
                class="inline-block w-3 h-3 rounded-full shrink-0"
                style={`background-color: ${p.color}`}
              ></span>
              <span class="font-heading text-base font-bold text-text-primary group-hover:text-compass-green transition-colors">
                {p.title}
              </span>
            </div>
            <p class="text-sm text-text-secondary mb-3">
              {p.description}
            </p>
            <span class="text-xs font-heading text-text-secondary">
              {p.articleCount > 0
                ? `${p.articleCount} article${p.articleCount === 1 ? "" : "s"}`
                : "Coming soon"}
            </span>
          </a>
        </div>
      ))}

      <div class="text-center">
        <a
          href="/big-picture"
          class="inline-block text-sm font-heading text-compass-green hover:underline transition-colors"
        >
          See how they connect &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Mini feedback loop + Email CTA -->
  <section class="py-12 md:py-16 bg-bg-secondary">
    <div class="max-w-content mx-auto px-4 md:px-0">
      <EmailCapture location="inline" />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 md:py-16 bg-compass-green-light">
    <div class="max-w-content mx-auto px-4 md:px-0 text-center">
      <h2 class="font-heading text-2xl font-bold text-text-primary mb-4">
        Start reading
      </h2>
      <p class="text-text-secondary mb-6">
        Begin with Article 1.1 — the foundation for everything that follows.
      </p>
      {
        firstArticle && (
          <a
            href={`/articles/${firstArticle.id.replace(/\.md$/, "")}`}
            class="inline-block px-6 py-3 bg-compass-green text-white font-heading font-semibold rounded hover:bg-compass-green-dark transition-colors"
          >
            Read: {firstArticle.data.title}
          </a>
        )
      }
    </div>
  </section>
</BaseLayout>
