---
import { getCollection, render } from "astro:content";
import ArticleLayout from "@layouts/ArticleLayout.astro";
import ShareButtons from "@components/ShareButtons.astro";
import ArticleNav from "@components/ArticleNav.astro";
import CrossLinks from "@components/CrossLinks.astro";
import ReadingProgress from "@components/ReadingProgress.astro";
import EmailCapture from "@components/EmailCapture.astro";
import ReformBar from "@components/identity/ReformBar.astro";
import { getSeriesNavigation } from "@utils/series-navigation";

// Gated, on-demand route: NOT prerendered, so the auth middleware runs for it
// and the reform articles never exist as public static files. Because it is
// server-rendered we resolve the entry from params at request time rather than
// via getStaticPaths, and 404 anything that isn't a reform-agenda article.
export const prerender = false;

const { slug } = Astro.params;
const allArticles = await getCollection("articles");
const article = allArticles.find(
  (a) => a.id.replace(/\.md$/, "") === slug,
);

if (!article || article.data.pillar !== "reform-agenda") {
  return new Response(null, { status: 404 });
}

const { Content, headings } = await render(article);
const articleUrl = new URL(`/reform/articles/${slug}`, Astro.site).href;
const seriesNav = getSeriesNavigation(article, allArticles);
---

<ReadingProgress />

<ArticleLayout
  title={article.data.title}
  subtitle={article.data.subtitle}
  description={article.data.description}
  articleNumber={article.data.articleNumber}
  pillar={article.data.pillar}
  part={article.data.part}
  sphere={article.data.sphere}
  publishDate={article.data.publishDate}
  readingTime={article.data.readingTime}
  canonicalUrl={article.data.seo.canonicalUrl}
  ogImage={article.data.seo.ogImage}
  series={article.data.series}
  headings={headings}
>
  <ReformBar slot="banner" />

  <Content />

  <div class="mt-8 pt-6 border-t border-gray-200">
    <ShareButtons
      title={article.data.title}
      subtitle={article.data.subtitle}
      url={articleUrl}
      slug={slug}
    />
  </div>

  {
    article.data.crossLinks && article.data.crossLinks.length > 0 && (
      <CrossLinks links={article.data.crossLinks} />
    )
  }

  <EmailCapture location="inline" />

  <ArticleNav prev={seriesNav.prev} next={seriesNav.next} />
</ArticleLayout>
