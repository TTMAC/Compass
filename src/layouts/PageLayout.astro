---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  width?: "content" | "wide";
}

const { title, description, canonicalUrl, ogImage, width = "content" } = Astro.props;

const containerClass =
  width === "wide"
    ? "max-w-5xl mx-auto px-4 md:px-6 py-12"
    : "max-w-content mx-auto px-4 md:px-0 py-12";
---

<BaseLayout
  title={`${title} — GovCompass`}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
>
  <div class={containerClass}>
    <slot />
  </div>
</BaseLayout>
