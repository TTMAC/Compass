---
import BaseLayout from "./BaseLayout.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { getPillarBySlug } from "@content/pillars";

interface Heading {
  depth: number;
  text: string;
  slug: string;
}

interface Props {
  title: string;
  subtitle: string;
  description: string;
  articleNumber: string;
  pillar?: string;
  part?: number;
  sphere?: ("national" | "provincial" | "municipal" | "all")[];
  publishDate: Date;
  readingTime: number;
  canonicalUrl?: string;
  ogImage?: string;
  series: {
    prev: string | null;
    next: string | null;
  };
  headings?: Heading[];
}

const {
  title,
  subtitle,
  description,
  articleNumber,
  pillar = "government-structure",
  part,
  sphere,
  publishDate,
  readingTime,
  canonicalUrl,
  ogImage,
  headings = [],
} = Astro.props;

const pillarConfig = getPillarBySlug(pillar);
const partConfig = pillarConfig?.parts.find((p) => p.number === part);

const sphereColors: Record<string, string> = {
  national: "bg-sphere-national",
  provincial: "bg-sphere-provincial",
  municipal: "bg-sphere-municipal",
  all: "bg-compass-green",
};

const formattedDate = publishDate.toLocaleDateString("en-ZA", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const siteUrl = Astro.site?.origin || "https://govcompass.co.za";

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description,
  datePublished: publishDate.toISOString(),
  author: {
    "@type": "Person",
    name: "Citizen X",
  },
  publisher: {
    "@type": "Organization",
    name: "GovCompass",
    url: siteUrl,
  },
};

const breadcrumbItems: { name: string; url: string }[] = [
  { name: "Home", url: siteUrl },
];
if (pillarConfig) {
  breadcrumbItems.push({
    name: pillarConfig.shortTitle,
    url: `${siteUrl}/pillars/${pillar}`,
  });
}
if (partConfig) {
  breadcrumbItems.push({
    name: `Part ${part}: ${partConfig.title}`,
    url: `${siteUrl}/pillars/${pillar}`,
  });
}
breadcrumbItems.push({
  name: title,
  url: `${siteUrl}${Astro.url.pathname}`,
});

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.name,
    item: item.url,
  })),
};

const jsonLd = [articleJsonLd, breadcrumbJsonLd];
---

<BaseLayout
  title={`${title} — GovCompass`}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
  jsonLd={jsonLd}
>
  <div class="article-grid">
    <article class="article-main px-4 md:px-0 py-8 md:py-12">
      {pillarConfig && (
        <nav class="flex items-center gap-1.5 text-xs font-heading text-text-secondary mb-4" aria-label="Breadcrumb">
          <a href={`/pillars/${pillar}`} class="hover:text-compass-green transition-colors" style={`color: ${pillarConfig.color}`}>
            {pillarConfig.shortTitle}
          </a>
          {partConfig && (
            <>
              <span aria-hidden="true">&rsaquo;</span>
              <span>Part {part}: {partConfig.title}</span>
            </>
          )}
          <span aria-hidden="true">&rsaquo;</span>
          <span>Article {articleNumber}</span>
        </nav>
      )}

      <header class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="font-heading text-sm text-text-secondary">
            Article {articleNumber}
          </span>
          {sphere?.map((s) => (
            <span
              class={`inline-block px-2 py-0.5 text-xs font-heading font-semibold text-white rounded ${sphereColors[s]}`}
            >
              {s.charAt(0).toUpperCase() + s.slice(1)}
            </span>
          ))}
        </div>

        <h1 class="font-heading text-3xl md:text-4xl font-bold text-text-primary mb-3 leading-tight">
          {title}
        </h1>

        <p class="text-lg md:text-xl text-text-secondary mb-4 font-body">
          {subtitle}
        </p>

        <div class="flex items-center gap-4 text-sm text-text-secondary font-heading">
          <span>Citizen X</span>
          <time datetime={publishDate.toISOString()}>
            {formattedDate}
          </time>
          <span aria-label={`${readingTime} minute read`}>
            {readingTime} min read
          </span>
        </div>

      </header>

      {headings.length > 0 && (
        <div class="toc-mobile-wrapper">
          <TableOfContents headings={headings} />
        </div>
      )}

      <div class="prose prose-article" data-testid="article-content">
        <slot />
      </div>
    </article>

    {headings.length > 0 && (
      <aside class="toc-sidebar">
        <TableOfContents headings={headings} />
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .article-grid {
    display: grid;
    grid-template-columns: 1fr;
    max-width: 680px;
    margin: 0 auto;
  }

  @media (min-width: 1100px) {
    .article-grid {
      grid-template-columns: 680px 240px;
      max-width: none;
      width: fit-content;
      margin: 0 auto;
      gap: 2rem;
    }
  }

  .article-main {
    max-width: 680px;
    min-width: 0;
  }

  .toc-mobile-wrapper {
    display: block;
  }

  .toc-sidebar {
    display: none;
  }

  @media (min-width: 1100px) {
    .toc-mobile-wrapper {
      display: none;
    }

    .toc-sidebar {
      display: block;
      align-self: start;
      position: sticky;
      top: 5rem;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
      padding-top: 3rem;
    }
  }

  .prose-article {
    font-size: 19px;
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .prose-article {
      font-size: 17px;
    }
  }

  .prose-article :global(h2) {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #1a1a1a;
  }

  .prose-article :global(h3) {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #1a1a1a;
  }

  .prose-article :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose-article :global(strong) {
    font-weight: 700;
  }

  .prose-article :global(a) {
    color: #355E3B;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose-article :global(a:hover) {
    color: #264A2C;
  }

  .prose-article :global(ul),
  .prose-article :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose-article :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose-article :global(blockquote) {
    border-left: 4px solid #355E3B;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #4a4a4a;
    font-style: italic;
  }

  /* Hero image */
  .hero-image {
    margin: 0;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .hero-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }

  @media (max-width: 768px) {
    .hero-image {
      margin-left: -1rem;
      margin-right: -1rem;
      border-radius: 0;
    }

    .hero-image img {
      border-radius: 0;
    }
  }

  /* Article images */
  .prose-article :global(figure.article-figure) {
    margin: 2rem 0;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .prose-article :global(figure.article-figure) {
      margin-left: -0.5rem;
      margin-right: -0.5rem;
      border-radius: 0;
    }
  }

  .prose-article :global(figure.article-figure img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.5rem 0.5rem 0 0;
  }

  @media (max-width: 768px) {
    .prose-article :global(figure.article-figure img) {
      border-radius: 0;
    }
  }

  .prose-article :global(figcaption.article-figcaption) {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: #6b6b6b;
    padding: 0.5rem 0;
  }

  .prose-article :global(.article-caption-text) {
    color: #4a4a4a;
  }

  .prose-article :global(.article-attribution) {
    font-size: 0.75rem;
    color: #9a9a9a;
  }

  .prose-article :global(.article-attribution a) {
    color: #9a9a9a;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose-article :global(.article-attribution a:hover) {
    color: #6b6b6b;
  }

  /* Tables */
  .prose-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.875rem;
    line-height: 1.5;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .prose-article :global(thead) {
    background-color: #F8F8F8;
    border-bottom: 2px solid #355E3B;
  }

  .prose-article :global(th) {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #1a1a1a;
    white-space: nowrap;
  }

  .prose-article :global(td) {
    padding: 0.75rem 1rem;
    color: #4a4a4a;
    border-bottom: 1px solid #e5e7eb;
    vertical-align: top;
  }

  .prose-article :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .prose-article :global(tbody tr:hover) {
    background-color: #f9fafb;
  }

  /* Responsive table wrapper */
  .prose-article :global(.table-wrapper) {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1.5rem 0;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
  }

  .prose-article :global(.table-wrapper table) {
    margin: 0;
  }

  @media (max-width: 768px) {
    .prose-article :global(table) {
      font-size: 0.8125rem;
    }

    .prose-article :global(th),
    .prose-article :global(td) {
      padding: 0.5rem 0.75rem;
    }
  }

  /* H4 within articles */
  .prose-article :global(h4) {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 1.0625rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
  }

  /* Timeline callout */
  .prose-article :global([data-callout="timeline"]) {
    position: relative;
  }

  .prose-article :global([data-callout="timeline"] table) {
    border: 1px solid #e5e7eb;
    border-radius: 0.375rem;
    overflow: hidden;
    background: #ffffff;
  }

  .prose-article :global([data-callout="timeline"] thead) {
    background-color: #355E3B;
    border-bottom: none;
  }

  .prose-article :global([data-callout="timeline"] th) {
    color: #ffffff;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prose-article :global([data-callout="timeline"] td) {
    font-size: 0.8125rem;
  }

  .prose-article :global([data-callout="timeline"] td:first-child) {
    font-weight: 600;
    color: #1a1a1a;
    white-space: nowrap;
  }

  .prose-article :global([data-callout="timeline"] h3) {
    font-size: 1.0625rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid #e5e7eb;
    color: #355E3B;
  }

  .prose-article :global([data-callout="timeline"] h3:first-of-type) {
    margin-top: 0.5rem;
  }

  .prose-article :global([data-callout="timeline"] p) {
    font-size: 0.9375rem;
    color: #4a4a4a;
  }
</style>
