---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import CookieConsent from "@components/CookieConsent.astro";
import "@styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonicalUrl,
  ogImage = "/og/default.png",
  ogType = "website",
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site?.origin || "https://govcompass.co.za";
const fullCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const fullOgImage = ogImage.startsWith("http")
  ? ogImage
  : new URL(ogImage, siteUrl).href;

const siteSchemas: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "GovCompass",
    url: siteUrl,
    description:
      "Making South Africa's government and governance systems legible to ordinary citizens",
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "GovCompass",
    url: siteUrl,
    description:
      "Free political education making SA's government and governance systems legible to ordinary citizens",
    inLanguage: "en-ZA",
  },
];

const allSchemas = [
  ...siteSchemas,
  ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
];
---

<html lang="en-ZA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />
    <meta name="theme-color" content="#355E3B" />

    <!-- Font preloads -->
    <link
      rel="preload"
      href="/fonts/Inter-Bold-Latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/SourceSerif4-Regular-Latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Preconnect for GA4 -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:site_name" content="GovCompass" />
    <meta property="og:locale" content="en_ZA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- JSON-LD -->
    {
      allSchemas.map((schema) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(schema)}
        />
      ))
    }

    <slot name="head" />
  </head>
  <body
    class="min-h-screen bg-bg-primary text-text-primary font-body flex flex-col"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-compass-green focus:text-white focus:rounded"
    >
      Skip to content
    </a>

    <Header />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer />

    <CookieConsent />

    <div
      id="sw-update-banner"
      class="hidden fixed bottom-4 left-1/2 -translate-x-1/2 z-50 px-4 py-3 rounded-lg shadow-lg bg-compass-green text-white font-heading text-sm flex items-center gap-3 max-w-[calc(100vw-2rem)]"
      role="status"
      aria-live="polite"
    >
      <span>A new version is available.</span>
      <button
        type="button"
        id="sw-update-reload"
        class="px-3 py-1 rounded bg-white text-compass-green font-semibold hover:bg-compass-green-light transition-colors"
      >
        Reload
      </button>
      <button
        type="button"
        id="sw-update-dismiss"
        class="text-white/80 hover:text-white"
        aria-label="Dismiss"
      >
        &times;
      </button>
    </div>

    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker
            .register("/sw.js")
            .then(function (registration) {
              function showUpdateBanner(waitingWorker) {
                var banner = document.getElementById("sw-update-banner");
                var reloadBtn = document.getElementById("sw-update-reload");
                var dismissBtn = document.getElementById("sw-update-dismiss");
                if (!banner || !reloadBtn || !dismissBtn) return;
                banner.classList.remove("hidden");
                reloadBtn.addEventListener("click", function () {
                  waitingWorker.postMessage("SKIP_WAITING");
                });
                dismissBtn.addEventListener("click", function () {
                  banner.classList.add("hidden");
                });
              }

              if (registration.waiting) {
                showUpdateBanner(registration.waiting);
              }

              registration.addEventListener("updatefound", function () {
                var newWorker = registration.installing;
                if (!newWorker) return;
                newWorker.addEventListener("statechange", function () {
                  if (
                    newWorker.state === "installed" &&
                    navigator.serviceWorker.controller
                  ) {
                    showUpdateBanner(newWorker);
                  }
                });
              });
            })
            .catch(function () {
              /* Registration failures should not break the page. */
            });

          var refreshing = false;
          navigator.serviceWorker.addEventListener(
            "controllerchange",
            function () {
              if (refreshing) return;
              refreshing = true;
              window.location.reload();
            },
          );
        });
      }
    </script>

    <!--
      Netlify Identity is the CMS auth widget. It is NOT loaded on normal
      reader pages — that would pull a third-party script (against our
      "no third-party scripts beyond GA4" rule) and add page weight for no
      reason. The actual CMS login lives on the self-contained /admin/ page,
      which loads its own copy of the widget.

      The only reason the widget needs to touch the public site is the
      invite / password-recovery / email-confirmation flow: those email links
      land on the site root with a token in the URL hash and must redirect to
      /admin/. So we lazy-inject the widget ONLY when such a token is present.
    -->
    <script is:inline>
      (function () {
        var h = window.location.hash || "";
        // Netlify Identity tokens that arrive via email links.
        if (
          !/(confirmation_token|invite_token|recovery_token|email_change_token)=/.test(
            h,
          )
        ) {
          return;
        }
        var s = document.createElement("script");
        s.src = "https://identity.netlify.com/v1/netlify-identity-widget.js";
        s.integrity =
          "sha384-dy2tW8xkhLIj8lZR42MCwZhhDb2cCewZiw0uA65CMpdHiJzL+iubx7HzHcCXU2rW";
        s.crossOrigin = "anonymous";
        s.onload = function () {
          if (!window.netlifyIdentity) return;
          window.netlifyIdentity.on("init", function (user) {
            if (!user) {
              window.netlifyIdentity.on("login", function () {
                document.location.href = "/admin/";
              });
            }
          });
        };
        document.body.appendChild(s);
      })();
    </script>
  </body>
</html>
