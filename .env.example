# Google Analytics 4 (PUBLIC_ prefix exposes to client-side code)
PUBLIC_GA4_ID=G-XXXXXXXXXX

# Resend (email) — set these in the Netlify dashboard for production.
# RESEND_API_KEY:     server-side API key from https://resend.com/api-keys
# RESEND_AUDIENCE_ID: ID of the audience subscribers are added to (https://resend.com/audiences)
# RESEND_FROM:        verified sender address, e.g. "GovCompass <hello@govcompass.co.za>"
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM=GovCompass <hello@govcompass.co.za>

# Clerk (auth for the private Reform section) — set these in the Netlify dashboard.
# Use a NEW, separate Clerk application (not the Prompt & Profit one).
# PUBLIC_CLERK_PUBLISHABLE_KEY: client-safe key (pk_test_… / pk_live_…) from https://dashboard.clerk.com
# CLERK_SECRET_KEY:             server-only secret (sk_test_… / sk_live_…) — never expose to the client.
# When both are unset the auth gate stays dormant (the site builds and runs without them).
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Unsplash API (for sourcing article images)
UNSPLASH_ACCESS_KEY=

# Site URL
SITE_URL=https://govcompass.co.za
